#!/usr/bin/env Rscript

# Standalone focal disparity bootstrap script
# -------------------------------------------
# This file is intentionally self-contained so it can be shared and sourced
# outside the bifrost package. Public entry points are suffixed with
# `Standalone` to avoid colliding with the package API while this file lives as
# a shareable script.

checkFocalDisparityStandalonePackages <- function() {
  required_pkgs <- c("ape", "mvMORPH", "future", "future.apply", "progressr")
  missing_pkgs <- required_pkgs[!vapply(required_pkgs, requireNamespace, logical(1), quietly = TRUE)]

  if (length(missing_pkgs) > 0L) {
    stop(
      "Missing required package(s): ",
      paste(missing_pkgs, collapse = ", "),
      "\nInstall with:\ninstall.packages(c(",
      paste(sprintf('"%s"', missing_pkgs), collapse = ", "),
      "))"
    )
  }

  invisible(TRUE)
}

isLegacyTraitDataReferenceStandalone <- function(expr) {
  is.symbol(expr) && identical(as.character(expr), "trait_data")
}

isLegacyTraitDataSubsetStandalone <- function(expr) {
  is.call(expr) &&
    identical(expr[[1L]], as.name("[")) &&
    length(expr) >= 2L &&
    is.symbol(expr[[2L]]) &&
    identical(as.character(expr[[2L]]), "trait_data")
}

collectLegacyTraitDataColumnsStandalone <- function(expr, data_names) {
  if (isLegacyTraitDataSubsetStandalone(expr)) {
    return(resolveLegacyTraitDataColumnsStandalone(expr, data_names))
  }
  if (!is.call(expr)) {
    return(integer(0))
  }
  unique(unlist(lapply(
    as.list(expr)[-1L],
    collectLegacyTraitDataColumnsStandalone,
    data_names = data_names
  )))
}

resolveLegacyTraitDataColumnsStandalone <- function(expr, data_names) {
  placeholder <- as.data.frame(
    setNames(
      lapply(seq_along(data_names), function(i) rep.int(i, 3L)),
      data_names
    ),
    check.names = FALSE,
    stringsAsFactors = FALSE
  )
  value <- tryCatch(
    eval(expr, envir = list(trait_data = placeholder)),
    error = function(e) e
  )
  if (inherits(value, "error")) {
    stop("Legacy trait_data indexing could not be resolved from the supplied formula.")
  }

  if (is.data.frame(value) || is.matrix(value)) {
    cols <- colnames(value)
    if (is.null(cols) || !all(cols %in% data_names)) {
      stop("Legacy trait_data indexing could not be resolved to named columns.")
    }
    return(match(cols, data_names))
  }

  unique_vals <- unique(as.integer(value))
  unique_vals <- unique_vals[!is.na(unique_vals)]
  if (length(unique_vals) == 0L || any(unique_vals < 1L) || any(unique_vals > length(data_names))) {
    stop("Legacy trait_data indexing could not be resolved to valid columns.")
  }
  unique_vals
}

rewriteLegacyTraitDataExprStandalone <- function(expr, data_names, side = c("lhs", "rhs")) {
  side <- match.arg(side)

  if (isLegacyTraitDataReferenceStandalone(expr)) {
    if (side == "lhs") {
      cols <- seq_along(data_names)
      names <- data_names[cols]
      if (length(names) == 1L) {
        return(as.name(names))
      }
      return(as.call(c(as.name("cbind"), lapply(names, as.name))))
    }
    return(expr)
  }

  if (isLegacyTraitDataSubsetStandalone(expr)) {
    cols <- resolveLegacyTraitDataColumnsStandalone(expr, data_names)
    names <- data_names[cols]
    if (side == "rhs" && length(names) != 1L) {
      stop("Legacy indexed predictors must resolve to single raw columns.")
    }
    if (length(names) == 1L) {
      return(as.name(names))
    }
    return(as.call(c(as.name("cbind"), lapply(names, as.name))))
  }

  if (!is.call(expr)) {
    return(expr)
  }

  as.call(lapply(
    as.list(expr),
    rewriteLegacyTraitDataExprStandalone,
    data_names = data_names,
    side = side
  ))
}

isSupportedNamedResponseStandalone <- function(expr) {
  if (is.symbol(expr) && !identical(as.character(expr), "trait_data")) {
    return(TRUE)
  }
  if (is.call(expr) && identical(expr[[1L]], as.name("cbind"))) {
    args <- as.list(expr)[-1L]
    return(length(args) > 0L && all(vapply(args, is.symbol, logical(1))))
  }
  FALSE
}

extractNamedResponseNamesStandalone <- function(lhs_expr, data_names) {
  if (is.symbol(lhs_expr)) {
    nm <- as.character(lhs_expr)
    if (!nm %in% data_names) {
      stop("Response variable referenced in formula was not found in trait_data.")
    }
    return(nm)
  }

  if (is.call(lhs_expr) && identical(lhs_expr[[1L]], as.name("cbind"))) {
    response_names <- vapply(as.list(lhs_expr)[-1L], as.character, character(1))
    if (!all(response_names %in% data_names)) {
      stop("One or more response variables referenced in formula were not found in trait_data.")
    }
    if (anyDuplicated(response_names)) {
      stop("Response variables in formula must be unique.")
    }
    return(response_names)
  }

  stop("Unsupported response form in formula.")
}

normalizeMvglsFormulaCallStandalone <- function(formula,
                                                trait_data,
                                                args_list,
                                                allow_single_response = FALSE) {
  if (missing(formula)) {
    stop("A character formula or formula object must be provided.")
  }

  if (inherits(formula, "formula")) {
    formula_obj <- formula
  } else if (is.character(formula) && length(formula) == 1L && !is.na(formula)) {
    formula_obj <- stats::as.formula(formula)
  } else {
    stop("A character formula or formula object must be provided.")
  }

  formula_chr <- paste(deparse(formula_obj, width.cutoff = 500), collapse = " ")
  data_obj <- if ("data" %in% names(args_list)) args_list$data else trait_data
  if (is.matrix(data_obj)) {
    data_obj <- as.data.frame(data_obj, stringsAsFactors = FALSE)
  }
  if (!is.null(rownames(trait_data)) && nrow(data_obj) == nrow(trait_data)) {
    rownames(data_obj) <- rownames(trait_data)
  }

  if (grepl("\\btrait_data\\b", formula_chr)) {
    formula_terms <- stats::terms(formula_obj)
    intercept_only <- length(attr(formula_terms, "term.labels")) == 0L &&
      identical(attr(formula_terms, "intercept"), 1L)
    lhs_is_trait_data <- is.symbol(formula_obj[[2L]]) &&
      identical(as.character(formula_obj[[2L]]), "trait_data")
    response_only_df <- is.data.frame(data_obj) &&
      ncol(data_obj) > 0L &&
      all(vapply(data_obj, is.numeric, logical(1)))

    if (intercept_only && lhs_is_trait_data && response_only_df) {
      response_names <- colnames(data_obj)
      if (is.null(response_names) || any(!nzchar(response_names))) {
        response_names <- paste0("Y", seq_len(ncol(data_obj)))
        colnames(data_obj) <- response_names
      }
      response_names <- make.unique(make.names(response_names))
      colnames(data_obj) <- response_names
      formula_obj <- if (length(response_names) == 1L) {
        stats::as.formula(paste0(response_names, " ~ 1"))
      } else {
        stats::as.formula(
          paste0("cbind(", paste(response_names, collapse = ", "), ") ~ 1")
        )
      }
      args_list$data <- data_obj
      formula_chr <- paste(deparse(formula_obj, width.cutoff = 500), collapse = " ")
    } else if (intercept_only && lhs_is_trait_data) {
      return(list(
        formula = formula_obj,
        args_list = args_list
      ))
    } else {
      data_names <- colnames(data_obj)
      has_missing_names <- is.null(data_names) || any(!nzchar(data_names))

      if (has_missing_names) {
        if (is.null(data_names)) {
          data_names <- rep("", ncol(data_obj))
        }
        missing_idx <- which(!nzchar(data_names))
        data_names[missing_idx] <- paste0("V", seq_along(missing_idx))
        data_names <- make.unique(make.names(data_names))
        colnames(data_obj) <- data_names
      }

      lhs_expr <- formula_obj[[2L]]
      rhs_expr <- formula_obj[[3L]]
      has_legacy_refs <- isLegacyTraitDataReferenceStandalone(lhs_expr) ||
        isLegacyTraitDataSubsetStandalone(lhs_expr) ||
        length(collectLegacyTraitDataColumnsStandalone(rhs_expr, colnames(data_obj))) > 0L

      if (!has_legacy_refs) {
        return(list(
          formula = formula_obj,
          args_list = args_list
        ))
      }

      if (intercept_only) {
        if (lhs_is_trait_data) {
          response_names <- colnames(data_obj)
        } else if (isLegacyTraitDataSubsetStandalone(lhs_expr)) {
          response_names <- colnames(data_obj)[resolveLegacyTraitDataColumnsStandalone(lhs_expr, colnames(data_obj))]
        } else if (isSupportedNamedResponseStandalone(lhs_expr)) {
          response_names <- extractNamedResponseNamesStandalone(lhs_expr, colnames(data_obj))
        } else {
          stop("Unsupported response form in intercept-only formula.")
        }

        data_obj <- data_obj[, response_names, drop = FALSE]
        rownames(data_obj) <- rownames(trait_data)
        args_list$data <- data_obj
        formula_obj <- stats::as.formula("trait_data ~ 1")
        formula_chr <- paste(deparse(formula_obj, width.cutoff = 500), collapse = " ")

        response_only_df <- is.data.frame(data_obj) &&
          ncol(data_obj) > 0L &&
          all(vapply(data_obj, is.numeric, logical(1)))

        if (response_only_df) {
          response_names <- colnames(data_obj)
          if (is.null(response_names) || any(!nzchar(response_names))) {
            response_names <- paste0("Y", seq_len(ncol(data_obj)))
            colnames(data_obj) <- response_names
          }
          response_names <- make.unique(make.names(response_names))
          colnames(data_obj) <- response_names
          formula_obj <- if (length(response_names) == 1L) {
            stats::as.formula(paste0(response_names, " ~ 1"))
          } else {
            stats::as.formula(
              paste0("cbind(", paste(response_names, collapse = ", "), ") ~ 1")
            )
          }
          args_list$data <- data_obj
          formula_chr <- paste(deparse(formula_obj, width.cutoff = 500), collapse = " ")
        }
      } else {
        if (isLegacyTraitDataReferenceStandalone(lhs_expr)) {
          stop("Legacy non-intercept formulas using bare 'trait_data' on the left-hand side are not supported. Use trait_data[, cols] or named columns.")
        }

        if (isLegacyTraitDataSubsetStandalone(lhs_expr)) {
          response_names <- colnames(data_obj)[resolveLegacyTraitDataColumnsStandalone(lhs_expr, colnames(data_obj))]
        } else if (isSupportedNamedResponseStandalone(lhs_expr)) {
          response_names <- extractNamedResponseNamesStandalone(lhs_expr, colnames(data_obj))
        } else {
          stop("Unsupported response form in formula.")
        }

        lhs_rewritten <- if (length(response_names) == 1L) {
          as.name(response_names)
        } else {
          as.call(c(as.name("cbind"), lapply(response_names, as.name)))
        }
        rhs_rewritten <- rewriteLegacyTraitDataExprStandalone(rhs_expr, colnames(data_obj), side = "rhs")
        formula_obj <- stats::as.formula(
          call("~", lhs_rewritten, rhs_rewritten),
          env = parent.frame()
        )
        formula_chr <- paste(deparse(formula_obj, width.cutoff = 500), collapse = " ")
        args_list$data <- data_obj
      }
    }
  }

  mf <- stats::model.frame(formula_obj, data = data_obj, na.action = stats::na.pass)
  response_block <- stats::model.response(mf)
  response_dim <- if (is.null(dim(response_block))) 1L else ncol(response_block)

  if (response_dim < 2L && !allow_single_response) {
    stop("Named formulas require a multivariate response for mvgls.")
  }

  if (response_dim >= 2L) {
    response_names <- colnames(response_block)
    if (is.null(response_names) || any(!nzchar(response_names))) {
      response_names <- paste0("Y", seq_len(response_dim))
    }
    response_names <- make.unique(make.names(response_names))
    colnames(response_block) <- response_names
  } else {
    lhs_expr <- formula_obj[[2L]]
    response_names <- if (is.symbol(lhs_expr)) as.character(lhs_expr) else NULL
    if (is.null(response_names) || any(!nzchar(response_names))) {
      response_names <- "Y1"
    }
    response_names <- make.unique(make.names(response_names))
    response_block <- as.matrix(response_block)
    colnames(response_block) <- response_names
  }

  rhs_terms <- stats::delete.response(attr(mf, "terms"))
  xmat <- stats::model.matrix(rhs_terms, mf)
  if ("(Intercept)" %in% colnames(xmat)) {
    xmat <- xmat[, colnames(xmat) != "(Intercept)", drop = FALSE]
  }

  if (ncol(xmat) > 0L) {
    predictor_names <- make.unique(make.names(colnames(xmat)))
    colnames(xmat) <- predictor_names
    working_data <- data.frame(
      response_block,
      xmat,
      check.names = FALSE,
      stringsAsFactors = FALSE
    )
    formula_fit <- stats::as.formula(
      paste0(
        "cbind(",
        paste(response_names, collapse = ", "),
        ") ~ ",
        paste(predictor_names, collapse = " + ")
      )
    )
  } else {
    working_data <- data.frame(
      response_block,
      check.names = FALSE,
      stringsAsFactors = FALSE
    )
    formula_fit <- stats::as.formula(
      paste0("cbind(", paste(response_names, collapse = ", "), ") ~ 1")
    )
  }

  rownames(working_data) <- rownames(data_obj)

  list(
    formula = formula_fit,
    args_list = {
      args_list$data <- working_data
      args_list
    }
  )
}

.standalone_resolve_focal_tips <- function(tree, focal) {
  if (is.character(focal)) {
    return(unique(focal))
  }

  if (is.logical(focal)) {
    if (length(focal) != ape::Ntip(tree)) {
      stop("Logical focal selectors must have length equal to ape::Ntip(tree).")
    }
    return(tree$tip.label[which(focal)])
  }

  if (is.numeric(focal) && length(focal) == 1L && !is.na(focal)) {
    node <- as.integer(focal)
    if (node <= ape::Ntip(tree)) {
      stop("Numeric focal values must be internal node numbers, not tip indices.")
    }
    if (node > (ape::Ntip(tree) + ape::Nnode(tree))) {
      stop("Numeric focal values must be internal node numbers present in tree.")
    }
    return(ape::extract.clade(tree, node = node)$tip.label)
  }

  stop("focal must be a character vector of tip labels, a logical tip selector, or a single internal node number.")
}

.standalone_align_inputs <- function(tree, trait_data, focal, min_focal_tips) {
  if (!inherits(tree, "phylo")) {
    tree <- tryCatch(
      ape::as.phylo(tree),
      error = function(e) NULL
    )
  }
  if (!inherits(tree, "phylo")) {
    stop("tree must be coercible to class 'phylo'.")
  }
  if (!is.matrix(trait_data) && !is.data.frame(trait_data)) {
    stop("trait_data must be a matrix or data.frame.")
  }
  if (is.null(rownames(trait_data))) {
    stop("trait_data must have row names matching tree tip labels.")
  }
  if (!is.numeric(min_focal_tips) || length(min_focal_tips) != 1L ||
      is.na(min_focal_tips) || min_focal_tips < 2) {
    stop("min_focal_tips must be a single integer >= 2.")
  }
  min_focal_tips <- as.integer(min_focal_tips)

  focal_tips_full <- .standalone_resolve_focal_tips(tree, focal)
  keep <- intersect(tree$tip.label, rownames(trait_data))
  if (length(keep) < 3L) {
    stop("Fewer than 3 overlapping taxa between tree and trait_data.")
  }

  aligned_tree <- if (length(keep) == ape::Ntip(tree)) {
    tree
  } else {
    ape::drop.tip(tree, setdiff(tree$tip.label, keep))
  }

  aligned_tree <- ape::reorder.phylo(aligned_tree, order = "postorder")
  aligned_trait_data <- trait_data[aligned_tree$tip.label, , drop = FALSE]
  focal_tips <- intersect(focal_tips_full, aligned_tree$tip.label)

  if (length(focal_tips) < min_focal_tips) {
    stop(sprintf(
      "Need at least %d focal tips after alignment; found %d.",
      min_focal_tips,
      length(focal_tips)
    ))
  }

  list(
    tree = aligned_tree,
    trait_data = aligned_trait_data,
    focal_tips = focal_tips
  )
}

.standalone_make_metric <- function(metric) {
  if (is.function(metric)) {
    return(list(fun = metric, label = "user_function"))
  }

  metric <- match.arg(
    metric,
    choices = c(
      "centroid_msd",
      "trace_cov",
      "mean_pairwise_sqdist",
      "log_det_cov",
      "max_eigenvalue",
      "eigenvalue_evenness"
    )
  )

  if (identical(metric, "centroid_msd")) {
    return(list(
      fun = function(X) {
        ctr <- colMeans(X)
        mean(rowSums((X - matrix(ctr, nrow(X), ncol(X), byrow = TRUE))^2))
      },
      label = metric
    ))
  }

  if (identical(metric, "trace_cov")) {
    return(list(
      fun = function(X) sum(diag(stats::cov(X))),
      label = metric
    ))
  }

  if (identical(metric, "log_det_cov")) {
    return(list(
      fun = function(X) {
        eigenvalues <- .standalone_cov_eigenvalues(X)
        sum(log(pmax(eigenvalues, .Machine$double.eps)))
      },
      label = metric
    ))
  }

  if (identical(metric, "max_eigenvalue")) {
    return(list(
      fun = function(X) max(.standalone_cov_eigenvalues(X)),
      label = metric
    ))
  }

  if (identical(metric, "eigenvalue_evenness")) {
    return(list(
      fun = function(X) {
        eigenvalues <- .standalone_cov_eigenvalues(X)
        total <- sum(eigenvalues)
        if (!is.finite(total) || total <= 0) {
          return(0)
        }

        weights <- eigenvalues[eigenvalues > 0] / total
        if (length(weights) <= 1L) {
          return(0)
        }

        -sum(weights * log(weights)) / log(length(eigenvalues))
      },
      label = metric
    ))
  }

  list(
    fun = function(X) {
      dmat <- as.matrix(stats::dist(X))
      mean(dmat[upper.tri(dmat)]^2)
    },
    label = metric
  )
}

.standalone_cov_eigenvalues <- function(X) {
  eigenvalues <- eigen(
    stats::cov(as.matrix(X)),
    symmetric = TRUE,
    only.values = TRUE
  )$values
  eigenvalues <- pmax(Re(eigenvalues), 0)
  eigenvalues[eigenvalues < .Machine$double.eps] <- 0
  eigenvalues
}

.standalone_eval_metric <- function(metric_fun, X) {
  value <- metric_fun(as.matrix(X))
  if (!is.numeric(value) || length(value) != 1L || !is.finite(value)) {
    stop("metric must return a single finite numeric value.")
  }
  as.numeric(value)
}

.standalone_extract_sigma_matrix <- function(fit) {
  sigma_hat <- fit$sigma

  if (is.null(sigma_hat)) {
    stop("Could not locate a sigma estimate in the fitted mvgls object.")
  }
  if (is.matrix(sigma_hat)) {
    return(as.matrix(sigma_hat))
  }
  if (is.list(sigma_hat) && !is.null(sigma_hat$S)) {
    return(as.matrix(sigma_hat$S))
  }
  if (is.list(sigma_hat) && !is.null(sigma_hat$Pinv)) {
    return(as.matrix(sigma_hat$Pinv))
  }

  stop("Could not extract a usable sigma matrix from the fitted mvgls object.")
}

.standalone_resolve_simulation_model <- function(fit_model) {
  switch(
    fit_model,
    BM = "BM1",
    OU = "OU1",
    EB = "EB",
    stop("model must be one of 'BM', 'OU', or 'EB'.")
  )
}

.standalone_expand_ou_alpha <- function(alpha, n_traits) {
  if (is.matrix(alpha)) {
    if (!identical(dim(alpha), c(n_traits, n_traits))) {
      stop("OU null simulation requires an alpha matrix with dimensions n_traits x n_traits.")
    }
    return(alpha)
  }

  alpha <- as.numeric(alpha)
  if (length(alpha) == 1L) {
    return(diag(alpha, n_traits))
  }
  if (length(alpha) == n_traits) {
    return(diag(alpha, n_traits))
  }

  stop("OU null simulation currently requires a scalar, length-n_traits vector, or square alpha matrix.")
}

.standalone_expand_eb_beta <- function(beta, n_traits) {
  if (is.matrix(beta)) {
    if (!identical(dim(beta), c(n_traits, n_traits))) {
      stop("EB null simulation requires a beta matrix with dimensions n_traits x n_traits.")
    }
    return(beta)
  }

  beta <- as.numeric(beta)
  if (length(beta) == 1L) {
    return(beta)
  }
  if (length(beta) == n_traits) {
    return(diag(beta, n_traits))
  }

  stop("EB null simulation currently requires a scalar, length-n_traits vector, or square beta matrix.")
}

.standalone_build_simulation_params <- function(fit, simulation_model, n_traits, sigma_hat) {
  params <- list(
    ntraits = n_traits,
    sigma = sigma_hat,
    theta = rep(0, n_traits)
  )

  fit_param <- fit$param
  if (identical(simulation_model, "OU1")) {
    if (is.null(fit_param) || anyNA(fit_param)) {
      stop("Could not extract OU alpha from the fitted mvgls object.")
    }
    params$alpha <- .standalone_expand_ou_alpha(fit_param, n_traits)
    return(params)
  }

  if (identical(simulation_model, "EB")) {
    if (is.null(fit_param) || anyNA(fit_param)) {
      stop("Could not extract EB beta from the fitted mvgls object.")
    }
    params$beta <- .standalone_expand_eb_beta(fit_param, n_traits)
    return(params)
  }

  params
}

.standalone_extract_simulated_matrix <- function(simulated, tip_labels, trait_names) {
  Ysim <- simulated
  if (is.list(Ysim)) {
    Ysim <- Ysim[[1L]]
  }
  if (length(dim(Ysim)) == 3L) {
    Ysim <- Ysim[, , 1L, drop = TRUE]
  }

  Ysim <- as.matrix(Ysim)
  rownames(Ysim) <- tip_labels
  colnames(Ysim) <- trait_names
  Ysim
}

.standalone_get_response_names <- function(fitted_values, residuals_matrix) {
  fitted_names <- colnames(fitted_values)
  if (!is.null(fitted_names) && length(fitted_names) > 0L) {
    return(as.character(fitted_names))
  }

  residual_names <- colnames(residuals_matrix)
  if (!is.null(residual_names) && length(residual_names) > 0L) {
    return(as.character(residual_names))
  }

  stop("Could not determine response column names from the fitted mvgls object.")
}

.standalone_replace_response_block <- function(data, response_names, response_matrix) {
  out <- as.data.frame(data, check.names = FALSE, stringsAsFactors = FALSE)
  response_df <- as.data.frame(response_matrix, check.names = FALSE, stringsAsFactors = FALSE)
  colnames(response_df) <- response_names
  out[, response_names] <- response_df[, response_names, drop = FALSE]
  out
}

.standalone_build_mvgls_call_args <- function(formula,
                                              data,
                                              tree,
                                              model,
                                              method,
                                              normalized_extra_args,
                                              extra_args) {
  c(
    list(
      formula = formula,
      data = data,
      tree = tree,
      model = model,
      method = method
    ),
    normalized_extra_args,
    extra_args
  )
}

.standalone_formula_from_string <- function(formula_chr) {
  stats::as.formula(formula_chr, env = baseenv())
}

.standalone_call_mvgls <- function(call_args) {
  call <- as.call(c(list(quote(mvMORPH::mvgls)), unname(call_args)))
  names(call)[-1] <- names(call_args)
  eval(call, envir = parent.frame())
}

.standalone_run_bootstrap <- function(nsim,
                                      sim_one,
                                      seed,
                                      show_progress,
                                      use_future) {
  if (isTRUE(use_future)) {
    if (isTRUE(show_progress)) {
      return(progressr::with_progress({
        progress <- progressr::progressor(steps = nsim)
        future.apply::future_sapply(
          X = seq_len(nsim),
          FUN = function(i) sim_one(i, progress = progress),
          future.seed = seed
        )
      }))
    }

    return(future.apply::future_sapply(
      X = seq_len(nsim),
      FUN = function(i) sim_one(i, progress = NULL),
      future.seed = seed
    ))
  }

  old_seed_exists <- exists(".Random.seed", envir = .GlobalEnv, inherits = FALSE)
  if (old_seed_exists) {
    old_seed <- get(".Random.seed", envir = .GlobalEnv, inherits = FALSE)
  }
  set.seed(seed)
  on.exit({
    if (old_seed_exists) {
      assign(".Random.seed", old_seed, envir = .GlobalEnv)
    } else if (exists(".Random.seed", envir = .GlobalEnv, inherits = FALSE)) {
      rm(".Random.seed", envir = .GlobalEnv)
    }
  }, add = TRUE)

  if (isTRUE(show_progress)) {
    return(progressr::with_progress({
      progress <- progressr::progressor(steps = nsim)
      vapply(
        X = seq_len(nsim),
        FUN = function(i) sim_one(i, progress = progress),
        FUN.VALUE = numeric(1)
      )
    }))
  }

  vapply(
    X = seq_len(nsim),
    FUN = function(i) sim_one(i, progress = NULL),
    FUN.VALUE = numeric(1)
  )
}

.standalone_summarize_null <- function(observed, null_statistics) {
  null_mean <- mean(null_statistics)
  null_sd <- stats::sd(null_statistics)
  ses <- if (is.finite(null_sd) && null_sd > 0) {
    (observed - null_mean) / null_sd
  } else {
    NA_real_
  }

  p_upper <- (1 + sum(null_statistics >= observed)) / (length(null_statistics) + 1)
  p_lower <- (1 + sum(null_statistics <= observed)) / (length(null_statistics) + 1)

  list(
    observed = observed,
    null_mean = null_mean,
    null_sd = null_sd,
    SES = ses,
    p_upper = p_upper,
    p_lower = p_lower,
    p_two_tailed = min(1, 2 * min(p_upper, p_lower))
  )
}

.standalone_find_example_focal_node <- function(tree, min_tips = 8L, max_tips = 15L) {
  nodes <- seq.int(ape::Ntip(tree) + 1L, ape::Ntip(tree) + ape::Nnode(tree))
  tip_counts <- vapply(
    nodes,
    function(node) length(ape::extract.clade(tree, node = node)$tip.label),
    integer(1)
  )

  eligible <- nodes[tip_counts >= min_tips & tip_counts <= max_tips]
  if (length(eligible) > 0L) {
    return(eligible[1L])
  }

  nodes[order(abs(tip_counts - round((min_tips + max_tips) / 2)))[1L]]
}

#' Create Reproducible Example Data for `testFocalDisparityStandalone()`
#'
#' @description
#' Generate a small synthetic example designed to yield elevated focal disparity
#' for a chosen subclade after accounting for a size covariate.
#'
#' @param seed Integer random seed controlling the tree, focal node, and data.
#'
#' @return A list with components `tree`, `trait_data`, `focal_node`, and
#'   `focal_tips`, suitable for passing directly to
#'   `testFocalDisparityStandalone()`.
#'
#' @examples
#' ex <- focalDisparityExampleDataStandalone(seed = 2)
#' names(ex)
#' length(ex$focal_tips)
focalDisparityExampleDataStandalone <- function(seed = 2L) {
  set.seed(seed)

  tree <- ape::rtree(40)
  focal_node <- .standalone_find_example_focal_node(tree, min_tips = 8L, max_tips = 14L)
  focal_tips <- ape::extract.clade(tree, node = focal_node)$tip.label

  n_tips <- ape::Ntip(tree)
  size <- stats::rnorm(n_tips)

  residual_block <- matrix(stats::rnorm(n_tips * 3L, sd = 0.2), ncol = 3L)
  focal_idx <- match(focal_tips, tree$tip.label)
  residual_block[focal_idx, ] <- cbind(
    stats::rnorm(length(focal_tips), sd = 0.95),
    stats::rnorm(length(focal_tips), sd = 0.85),
    stats::rnorm(length(focal_tips), sd = 0.9)
  )

  trait_data <- data.frame(
    y1 = 0.8 * size + residual_block[, 1L],
    y2 = -0.5 * size + residual_block[, 2L],
    y3 = 0.35 * size + residual_block[, 3L],
    size = size
  )
  rownames(trait_data) <- tree$tip.label

  list(
    tree = tree,
    trait_data = trait_data,
    focal_node = focal_node,
    focal_tips = focal_tips
  )
}

.standalone_fit_prepared_data <- function(tree,
                                          trait_data,
                                          formula,
                                          model,
                                          method,
                                          extra_args) {
  normalized <- normalizeMvglsFormulaCallStandalone(
    formula = formula,
    trait_data = trait_data,
    args_list = list(data = trait_data),
    allow_single_response = FALSE
  )

  fit_formula <- normalized$formula
  fit_data <- normalized$args_list$data
  if (is.null(fit_data)) {
    stop("Could not construct a data argument for mvgls.")
  }
  fit_data <- as.data.frame(fit_data, check.names = FALSE, stringsAsFactors = FALSE)
  rownames(fit_data) <- tree$tip.label

  formula_input_chr <- if (inherits(formula, "formula")) {
    paste(deparse(formula, width.cutoff = 500), collapse = " ")
  } else {
    as.character(formula)[1L]
  }
  fit_formula_chr <- paste(deparse(fit_formula, width.cutoff = 500), collapse = " ")

  normalized_extra_args <- normalized$args_list[setdiff(names(normalized$args_list), "data")]
  fit_call_args <- .standalone_build_mvgls_call_args(
    formula = .standalone_formula_from_string(fit_formula_chr),
    data = fit_data,
    tree = tree,
    model = model,
    method = method,
    normalized_extra_args = normalized_extra_args,
    extra_args = extra_args
  )

  fit <- .standalone_call_mvgls(fit_call_args)

  residuals_matrix <- as.matrix(stats::residuals(fit))
  rownames(residuals_matrix) <- tree$tip.label
  fitted_values <- as.matrix(fit$fitted)
  rownames(fitted_values) <- tree$tip.label
  response_names <- .standalone_get_response_names(
    fitted_values = fitted_values,
    residuals_matrix = residuals_matrix
  )
  colnames(residuals_matrix) <- response_names
  colnames(fitted_values) <- response_names

  list(
    tree = tree,
    trait_data = trait_data,
    fit_data = fit_data,
    fit = fit,
    residuals_matrix = residuals_matrix,
    fitted_values = fitted_values,
    response_names = response_names,
    formula_input_chr = formula_input_chr,
    fit_formula_chr = fit_formula_chr,
    normalized_extra_args = normalized_extra_args
  )
}

.standalone_prepare_focal_fit <- function(tree,
                                          trait_data,
                                          focal,
                                          formula,
                                          model,
                                          method,
                                          min_focal_tips,
                                          extra_args) {
  aligned <- .standalone_align_inputs(
    tree = tree,
    trait_data = trait_data,
    focal = focal,
    min_focal_tips = min_focal_tips
  )

  prepared <- .standalone_fit_prepared_data(
    tree = aligned$tree,
    trait_data = aligned$trait_data,
    formula = formula,
    model = model,
    method = method,
    extra_args = extra_args
  )
  prepared$focal_tips <- aligned$focal_tips
  prepared
}

.standalone_prepare_subtree_fit <- function(tree,
                                            trait_data,
                                            tips,
                                            formula,
                                            model,
                                            method,
                                            min_subtree_tips,
                                            extra_args,
                                            subset_label) {
  tips <- unique(intersect(tips, intersect(tree$tip.label, rownames(trait_data))))
  if (length(tips) < min_subtree_tips) {
    stop(
      subset_label,
      " subset must contain at least ",
      min_subtree_tips,
      " tips after alignment; found ",
      length(tips),
      "."
    )
  }

  subtree <- ape::keep.tip(tree, tip = tips)
  subtree <- ape::reorder.phylo(subtree, order = "postorder")
  subtree_data <- trait_data[subtree$tip.label, , drop = FALSE]

  prepared <- .standalone_fit_prepared_data(
    tree = subtree,
    trait_data = subtree_data,
    formula = formula,
    model = model,
    method = method,
    extra_args = extra_args
  )
  prepared$subset_tips <- subtree$tip.label
  prepared
}

.standalone_sigma_to_correlation <- function(sigma_matrix) {
  sigma_matrix <- as.matrix(sigma_matrix)
  sd_vec <- sqrt(diag(sigma_matrix))
  denom <- outer(sd_vec, sd_vec, "*")
  corr <- sigma_matrix / denom
  corr[!is.finite(corr)] <- NA_real_
  diag(corr) <- 1
  corr
}

.standalone_correlation_dendrogram <- function(corr_matrix) {
  corr_matrix <- as.matrix(corr_matrix)
  corr_matrix[!is.finite(corr_matrix)] <- 0
  corr_matrix <- pmin(pmax(corr_matrix, -1), 1)
  dist_matrix <- 1 - corr_matrix
  dist_matrix <- (dist_matrix + t(dist_matrix)) / 2
  diag(dist_matrix) <- 0
  stats::as.dendrogram(stats::hclust(stats::as.dist(dist_matrix)))
}

.standalone_plot_matrix_heatmap <- function(matrix_data,
                                            main,
                                            palette,
                                            row_dendrogram,
                                            zlim = NULL,
                                            cexRow = 0.7,
                                            cexCol = 0.7,
                                            margins = c(8, 8),
                                            summary_text = NULL,
                                            show_values = TRUE,
                                            value_digits = 2) {
  heatmap_args <- list(
    x = matrix_data,
    Rowv = row_dendrogram,
    Colv = "Rowv",
    symm = TRUE,
    scale = "none",
    col = palette,
    margins = margins,
    cexRow = cexRow,
    cexCol = cexCol,
    keep.dendro = FALSE,
    main = main
  )
  if (!is.null(zlim)) {
    heatmap_args$zlim <- zlim
  }
  do.call(stats::heatmap, heatmap_args)

  matrix_ord <- as.matrix(matrix_data)
  if (!is.null(row_dendrogram)) {
    ord <- stats::order.dendrogram(row_dendrogram)
    matrix_ord <- matrix_ord[ord, ord, drop = FALSE]
  }

  if (isTRUE(show_values)) {
    n <- nrow(matrix_ord)
    coords <- expand.grid(x = seq_len(n), y = seq_len(n))
    values <- as.vector(t(matrix_ord[n:1, , drop = FALSE]))
    text_col <- rep("black", length(values))
    if (!is.null(zlim) && all(is.finite(zlim)) && diff(zlim) > 0) {
      mid <- mean(zlim)
      text_col[abs(values - mid) > 0.35 * diff(zlim)] <- "white"
    }
    graphics::text(
      coords$x,
      coords$y,
      labels = formatC(values, format = "f", digits = value_digits),
      cex = min(0.9, 1.8 / max(1, n)),
      col = text_col
    )
  }

  if (!is.null(summary_text)) {
    graphics::mtext(summary_text, side = 1, line = max(3.2, margins[1] - 4), cex = 0.75)
  }
}

.standalone_matrix_eigenvalues <- function(matrix_data) {
  eigenvalues <- eigen(
    as.matrix(matrix_data),
    symmetric = TRUE,
    only.values = TRUE
  )$values
  eigenvalues <- pmax(Re(eigenvalues), 0)
  eigenvalues[eigenvalues < .Machine$double.eps] <- 0
  eigenvalues
}

.standalone_eigenvalue_evenness_from_values <- function(eigenvalues) {
  total <- sum(eigenvalues)
  if (!is.finite(total) || total <= 0) {
    return(0)
  }

  weights <- eigenvalues[eigenvalues > 0] / total
  if (length(weights) <= 1L) {
    return(0)
  }

  -sum(weights * log(weights)) / log(length(eigenvalues))
}

.standalone_offdiag_values <- function(matrix_data) {
  matrix_data <- as.matrix(matrix_data)
  if (nrow(matrix_data) < 2L || ncol(matrix_data) < 2L) {
    return(numeric())
  }
  matrix_data[upper.tri(matrix_data)]
}

.standalone_safe_ratio <- function(numerator, denominator) {
  if (!is.finite(numerator) || !is.finite(denominator) || denominator == 0) {
    return(NA_real_)
  }
  numerator / denominator
}

.standalone_summarize_subtree_matrices <- function(covariance,
                                                   correlation,
                                                   fit_model,
                                                   subset,
                                                   tip_labels) {
  eigenvalues <- .standalone_matrix_eigenvalues(covariance)
  trace_cov <- sum(diag(covariance))
  log_det_cov <- sum(log(pmax(eigenvalues, .Machine$double.eps)))
  max_eigenvalue <- if (length(eigenvalues) > 0L) max(eigenvalues) else NA_real_
  lead_eigenvalue_prop <- .standalone_safe_ratio(max_eigenvalue, sum(eigenvalues))
  offdiag_corr <- .standalone_offdiag_values(correlation)

  data.frame(
    model = fit_model,
    subset = subset,
    n_tips = length(tip_labels),
    n_traits = ncol(covariance),
    trace_cov = as.numeric(trace_cov),
    log_det_cov = as.numeric(log_det_cov),
    max_eigenvalue = as.numeric(max_eigenvalue),
    lead_eigenvalue_prop = as.numeric(lead_eigenvalue_prop),
    eigenvalue_evenness = as.numeric(.standalone_eigenvalue_evenness_from_values(eigenvalues)),
    mean_abs_correlation = if (length(offdiag_corr) > 0L) {
      mean(abs(offdiag_corr), na.rm = TRUE)
    } else {
      NA_real_
    },
    max_abs_correlation = if (length(offdiag_corr) > 0L) {
      max(abs(offdiag_corr), na.rm = TRUE)
    } else {
      NA_real_
    },
    stringsAsFactors = FALSE
  )
}

.standalone_build_subtree_contrast_table <- function(summary_table) {
  if (is.null(summary_table) || nrow(summary_table) == 0L) {
    return(data.frame())
  }

  contrast_rows <- list()
  row_index <- 1L
  for (model_i in unique(summary_table$model)) {
    focal_row <- summary_table[
      summary_table$model == model_i & summary_table$subset == "focal",
      ,
      drop = FALSE
    ]
    background_row <- summary_table[
      summary_table$model == model_i & summary_table$subset == "background",
      ,
      drop = FALSE
    ]

    if (nrow(focal_row) != 1L || nrow(background_row) != 1L) {
      next
    }

    contrast_rows[[row_index]] <- data.frame(
      model = model_i,
      focal_tips = focal_row$n_tips,
      background_tips = background_row$n_tips,
      trace_cov_ratio = .standalone_safe_ratio(focal_row$trace_cov, background_row$trace_cov),
      log_det_cov_diff = focal_row$log_det_cov - background_row$log_det_cov,
      max_eigenvalue_ratio = .standalone_safe_ratio(
        focal_row$max_eigenvalue,
        background_row$max_eigenvalue
      ),
      lead_eigenvalue_prop_diff = focal_row$lead_eigenvalue_prop -
        background_row$lead_eigenvalue_prop,
      eigenvalue_evenness_diff = focal_row$eigenvalue_evenness -
        background_row$eigenvalue_evenness,
      mean_abs_correlation_diff = focal_row$mean_abs_correlation -
        background_row$mean_abs_correlation,
      max_abs_correlation_diff = focal_row$max_abs_correlation -
        background_row$max_abs_correlation,
      stringsAsFactors = FALSE
    )
    row_index <- row_index + 1L
  }

  if (length(contrast_rows) == 0L) {
    return(data.frame())
  }

  out <- do.call(rbind, contrast_rows)
  rownames(out) <- NULL
  out
}

.standalone_print_subtree_covariance_table <- function(df, digits = 4) {
  df <- as.data.frame(df, stringsAsFactors = FALSE)
  num_cols <- vapply(df, is.numeric, logical(1))
  df[num_cols] <- lapply(df[num_cols], function(x) signif(x, digits = digits))
  print(df, row.names = FALSE)
}

#' Test Focal Disparity by Parametric Bootstrap
#'
#' @description
#' Standalone counterpart of `testFocalDisparity()`. It fits a multivariate
#' phylogenetic GLS model with `mvMORPH::mvgls()`, computes a focal disparity
#' statistic on the residuals of a focal set of tips, and compares that
#' observed value to a parametric bootstrap null distribution.
#'
#' @param tree A rooted phylogeny of class `phylo` or coercible with
#'   `ape::as.phylo()`.
#' @param trait_data A numeric matrix or data frame with row names matching tip
#'   labels in `tree`. Extra rows or tree tips are dropped by intersection.
#' @param focal Focal definition. Supply either a character vector of tip labels,
#'   a logical selector of length `ape::Ntip(tree)`, or a single internal node
#'   number whose descendant tips define the focal clade.
#' @param formula Formula passed to `mvMORPH::mvgls()`. Named-column formulas
#'   such as `cbind(y1, y2) ~ size + group` are supported, as are response-only
#'   matrix workflows such as `"trait_data ~ 1"`. Legacy indexed formulas that
#'   reference subsets of `trait_data` directly are also supported and are
#'   internally rewritten onto named columns, for example
#'   `"trait_data[, 1:5] ~ 1"` or `"trait_data[, 2:12] ~ trait_data[, 1]"`.
#' @param metric Either one of `"centroid_msd"`, `"trace_cov"`,
#'   `"mean_pairwise_sqdist"`, `"log_det_cov"`, `"max_eigenvalue"`, or
#'   `"eigenvalue_evenness"`, or a function that accepts the focal residual
#'   matrix and returns a single numeric value. The built-in options are all
#'   disparity/dispersion summaries, including covariance-volume and
#'   eigenspectrum-based measures: `"centroid_msd"` is mean squared Euclidean
#'   distance from the centroid; `"trace_cov"` is total variance (the
#'   covariance trace); `"mean_pairwise_sqdist"` is mean squared pairwise
#'   Euclidean distance; `"log_det_cov"` is the log generalized variance;
#'   `"max_eigenvalue"` emphasizes the dominant axis of variation; and
#'   `"eigenvalue_evenness"` summarizes how evenly variance is distributed
#'   across axes on a 0 to 1 scale.
#' @param nsim Integer number of bootstrap replicates.
#' @param model Character `mvgls` fit-model code used for the observed fit,
#'   bootstrap simulations, and each bootstrap refit. Supported values are
#'   `"BM"`, `"OU"`, and `"EB"`: `"BM"` is a Brownian-motion model,
#'   `"OU"` is a single-regime Ornstein-Uhlenbeck model, and `"EB"` is an
#'   early-burst model with exponentially changing evolutionary rates through
#'   time.
#' @param method Character fitting method passed to `mvMORPH::mvgls()`.
#' @param workers Integer number of workers used when `future_plan` is
#'   `"multisession"` or `"multicore"`.
#' @param seed Integer seed passed to `future.apply` for reproducible bootstrap
#'   streams.
#' @param future_plan Future backend used for bootstrap refits. One of
#'   `"multisession"`, `"multicore"`, or `"sequential"`. If `NULL`, the
#'   function uses `"sequential"` when `workers = 1` and `"multisession"`
#'   otherwise.
#' @param show_progress Logical; if `TRUE`, wrap bootstrap evaluation in
#'   `progressr::with_progress()`. Users can set their preferred progress
#'   handler with `progressr::handlers()`.
#' @param min_focal_tips Minimum number of focal tips required after alignment.
#' @param ... Additional arguments passed to `mvMORPH::mvgls()` for both the
#'   observed fit and bootstrap refits.
#'
#' @details
#' The bootstrap null simulates a residual process under the same single-regime
#' model used for fitting: `"BM"` uses `mvSIM(model = "BM1")`, `"OU"` uses
#' `mvSIM(model = "OU1")`, and `"EB"` uses `mvSIM(model = "EB")`. The fitted
#' residual covariance matrix and fitted mean structure from the observed
#' `mvgls` model are reused in each bootstrap replicate.
#'
#' The built-in metric choices emphasize different aspects of focal disparity:
#' `centroid_msd`, `trace_cov`, and `mean_pairwise_sqdist` target overall
#' spread; `log_det_cov` measures covariance volume; `max_eigenvalue`
#' emphasizes the largest principal axis; and `eigenvalue_evenness` measures
#' how evenly disparity is distributed across dimensions rather than how large
#' total disparity is.
#'
#' The supported models are intentionally restricted to single-regime nulls so
#' the fitted model and bootstrap model stay aligned: Brownian motion (`"BM"`),
#' Ornstein-Uhlenbeck (`"OU"`), and early burst (`"EB"`).
#'
#' If `focal` is supplied as an internal node number, descendant tips are
#' resolved on the original tree before overlap pruning, so the focal definition
#' remains stable when non-overlapping taxa are dropped during alignment.
#'
#' @return A list of class `bifrost_focal_disparity_test_standalone` containing
#'   the aligned data, the fitted `mvgls` object, the focal tip set, the
#'   observed statistic, the bootstrap null distribution, and standardized
#'   effect-size and p-value summaries.
#'
#' @examples
#' \dontrun{
#' ex <- focalDisparityExampleDataStandalone(seed = 2)
#'
#' res <- testFocalDisparityStandalone(
#'   tree = ex$tree,
#'   trait_data = ex$trait_data,
#'   focal = ex$focal_tips,
#'   formula = cbind(y1, y2, y3) ~ size,
#'   metric = "centroid_msd",
#'   nsim = 100,
#'   model = "BM",
#'   method = "LL",
#'   workers = 1,
#'   future_plan = "sequential",
#'   show_progress = FALSE,
#'   seed = 2
#' )
#'
#' print(res)
#' plot(res)
#' }
testFocalDisparityStandalone <- function(tree,
                                         trait_data,
                                         focal,
                                         formula = "trait_data ~ 1",
                                         metric = c(
                                           "centroid_msd",
                                           "trace_cov",
                                           "mean_pairwise_sqdist",
                                           "log_det_cov",
                                           "max_eigenvalue",
                                           "eigenvalue_evenness"
                                         ),
                                         nsim = 999,
                                         model = "BM",
                                         method = "PL-LOOCV",
                                         workers = future::availableCores(),
                                         seed = 1,
                                         future_plan = NULL,
                                         show_progress = TRUE,
                                         min_focal_tips = 3L,
                                         ...) {
  checkFocalDisparityStandalonePackages()

  extra_args <- list(...)
  reserved_args <- intersect(
    c("formula", "tree", "model", "data", "method"),
    names(extra_args)
  )
  if (length(reserved_args) > 0L) {
    stop(
      "Do not pass reserved mvgls arguments via ...: ",
      paste(reserved_args, collapse = ", "),
      "."
    )
  }

  if (!is.numeric(nsim) || length(nsim) != 1L || is.na(nsim) || nsim < 1) {
    stop("nsim must be a single integer >= 1.")
  }
  if (!is.numeric(workers) || length(workers) != 1L || is.na(workers) || workers < 1) {
    stop("workers must be a single integer >= 1.")
  }

  nsim <- as.integer(nsim)
  workers <- as.integer(workers)
  model <- match.arg(model, choices = c("BM", "OU", "EB"))

  if (is.null(future_plan)) {
    future_plan <- if (workers > 1L) "multisession" else "sequential"
  } else {
    future_plan <- match.arg(future_plan, choices = c("multisession", "multicore", "sequential"))
  }

  prepared <- .standalone_prepare_focal_fit(
    tree = tree,
    trait_data = trait_data,
    focal = focal,
    formula = formula,
    model = model,
    method = method,
    min_focal_tips = min_focal_tips,
    extra_args = extra_args
  )
  tree <- prepared$tree
  trait_data <- prepared$trait_data
  focal_tips <- prepared$focal_tips
  fit_data <- prepared$fit_data
  fit <- prepared$fit
  residuals_observed <- prepared$residuals_matrix
  fitted_values <- prepared$fitted_values
  response_names <- prepared$response_names
  formula_input_chr <- prepared$formula_input_chr
  fit_formula_chr <- prepared$fit_formula_chr
  normalized_extra_args <- prepared$normalized_extra_args

  metric_spec <- .standalone_make_metric(metric)
  observed_statistic <- .standalone_eval_metric(
    metric_fun = metric_spec$fun,
    X = residuals_observed[focal_tips, , drop = FALSE]
  )

  simulation_model <- .standalone_resolve_simulation_model(model)
  sigma_hat <- .standalone_extract_sigma_matrix(fit)
  null_simulation_params <- .standalone_build_simulation_params(
    fit = fit,
    simulation_model = simulation_model,
    n_traits = ncol(fitted_values),
    sigma_hat = sigma_hat
  )

  sim_tree <- ape::reorder.phylo(ape::as.phylo(tree), order = "postorder")
  extract_simulated_matrix <- .standalone_extract_simulated_matrix
  replace_response_block <- .standalone_replace_response_block
  build_mvgls_call_args <- .standalone_build_mvgls_call_args
  formula_from_string <- .standalone_formula_from_string
  call_mvgls <- .standalone_call_mvgls
  eval_metric <- .standalone_eval_metric
  metric_fun <- metric_spec$fun

  sim_one <- function(i, progress = NULL) {
    if (!is.null(progress)) {
      progress(sprintf("simulation %d/%d", i, nsim))
    }

    simulated <- mvMORPH::mvSIM(
      tree = sim_tree,
      nsim = 1,
      model = simulation_model,
      param = null_simulation_params
    )

    simulated_residuals <- extract_simulated_matrix(
      simulated = simulated,
      tip_labels = sim_tree$tip.label,
      trait_names = response_names
    )
    simulated_response <- fitted_values + simulated_residuals
    rownames(simulated_response) <- tree$tip.label
    colnames(simulated_response) <- response_names

    simulated_data <- replace_response_block(
      data = fit_data,
      response_names = response_names,
      response_matrix = simulated_response
    )
    simulated_data <- as.data.frame(
      simulated_data,
      check.names = FALSE,
      stringsAsFactors = FALSE
    )
    rownames(simulated_data) <- tree$tip.label

    sim_fit <- call_mvgls(
      build_mvgls_call_args(
        formula = formula_from_string(fit_formula_chr),
        data = simulated_data,
        tree = tree,
        model = model,
        method = method,
        normalized_extra_args = normalized_extra_args,
        extra_args = extra_args
      )
    )

    residuals_simulated <- as.matrix(stats::residuals(sim_fit))
    rownames(residuals_simulated) <- tree$tip.label
    eval_metric(
      metric_fun = metric_fun,
      X = residuals_simulated[focal_tips, , drop = FALSE]
    )
  }

  old_plan <- future::plan()
  on.exit(future::plan(old_plan), add = TRUE)

  if (identical(future_plan, "multisession")) {
    future::plan(future::multisession, workers = workers)
  } else if (identical(future_plan, "multicore")) {
    future::plan(future::multicore, workers = workers)
  } else {
    future::plan(future::sequential)
  }

  null_statistics <- .standalone_run_bootstrap(
    nsim = nsim,
    sim_one = sim_one,
    seed = seed,
    show_progress = show_progress,
    use_future = !identical(future_plan, "sequential")
  )

  null_statistics <- unname(as.numeric(null_statistics))
  summary_stats <- .standalone_summarize_null(
    observed = observed_statistic,
    null_statistics = null_statistics
  )

  out <- list(
    call = match.call(),
    fit = fit,
    tree = tree,
    focal_input = focal,
    trait_data = trait_data,
    fit_data = fit_data,
    focal_tips = focal_tips,
    formula_input = formula_input_chr,
    fit_formula = fit_formula_chr,
    metric = metric_spec$label,
    observed_statistic = summary_stats$observed,
    null_statistics = null_statistics,
    null_mean = summary_stats$null_mean,
    null_sd = summary_stats$null_sd,
    SES = summary_stats$SES,
    p_upper = summary_stats$p_upper,
    p_lower = summary_stats$p_lower,
    p_two_tailed = summary_stats$p_two_tailed,
    nsim = nsim,
    fit_model = model,
    simulation_model = simulation_model,
    method = method,
    workers = workers,
    seed = seed
  )

  class(out) <- c("bifrost_focal_disparity_test_standalone", class(out))
  out
}

#' Plot Residual Morphospace for a Focal Disparity Model
#'
#' @description
#' Standalone counterpart of `plotFocalResidualPCA()`. It fits the same
#' multivariate phylogenetic GLS model used by
#' `testFocalDisparityStandalone()`, performs an ordinary PCA on the fitted
#' residual matrix with `stats::prcomp()`, and plots focal versus background
#' taxa in the chosen residual morphospace dimensions.
#'
#' @param tree A rooted phylogeny of class `phylo` or coercible with
#'   `ape::as.phylo()`.
#' @param trait_data A numeric matrix or data frame with row names matching tip
#'   labels in `tree`.
#' @param focal Focal definition. Supply either a character vector of tip
#'   labels, a logical selector of length `ape::Ntip(tree)`, or a single
#'   internal node number.
#' @param formula Formula passed to `mvMORPH::mvgls()`. Supports the same named,
#'   response-only, and legacy indexed styles as
#'   `testFocalDisparityStandalone()`.
#' @param model Character fit-model code or vector of fit-model codes.
#'   Supported values are `"BM"`, `"OU"`, and `"EB"`. Supply multiple
#'   models, such as `c("BM", "OU", "EB")`, to draw one residual morphospace
#'   panel per model.
#' @param method Character fitting method passed to `mvMORPH::mvgls()`.
#' @param pc_x Integer principal-component index for the x-axis.
#' @param pc_y Integer principal-component index for the y-axis.
#' @param center Logical; passed to `stats::prcomp()`.
#' @param scale. Logical; passed to `stats::prcomp()`.
#' @param focal_col Color for focal taxa.
#' @param background_col Color for non-focal taxa.
#' @param focal_pch Plotting symbol for focal taxa.
#' @param background_pch Plotting symbol for non-focal taxa.
#' @param point_cex Point size passed to `graphics::plot()`.
#' @param show_legend Logical; if `TRUE`, draw a legend.
#' @param legend_position Legend position passed to `graphics::legend()`.
#' @param focal_label Legend label for focal taxa.
#' @param background_label Legend label for non-focal taxa.
#' @param use_shared_limits Logical; if `TRUE` and multiple models are drawn,
#'   use shared x- and y-axis limits across all panels.
#' @param show_centroids Logical; if `TRUE`, draw group centroids.
#' @param centroid_cex Point size for centroid markers.
#' @param centroid_pch Plotting symbol used for centroid markers.
#' @param centroid_lwd Line width for centroid markers.
#' @param show_hulls Logical; if `TRUE`, draw convex hulls for focal and
#'   background groups when enough points are available.
#' @param hull_alpha Alpha transparency used for hull fill colors.
#' @param hull_lwd Line width for hull borders.
#' @param layout Optional length-2 numeric vector giving the panel layout passed
#'   to `graphics::par()` as `mfrow` when multiple models are supplied. If
#'   `NULL`, a sensible layout is chosen automatically.
#' @param main Plot title. Defaults to a model-aware residual morphospace title.
#'   A single value is recycled across panels; a character vector of the same
#'   length as `model` can supply panel-specific titles.
#' @param xlab X-axis label. Defaults to `PCk` plus explained variance. A single
#'   value is recycled across panels; a character vector of the same length as
#'   `model` can supply panel-specific labels.
#' @param ylab Y-axis label. Defaults to `PCk` plus explained variance. A single
#'   value is recycled across panels; a character vector of the same length as
#'   `model` can supply panel-specific labels.
#' @param min_focal_tips Minimum number of focal tips required after alignment.
#' @param ... Additional arguments passed to `mvMORPH::mvgls()`.
#'
#' @details
#' This helper is intended as a descriptive follow-up to the focal disparity
#' test. It does not use `mvgls.pca`; instead it applies ordinary PCA to the
#' fitted residual matrix so the plotted point cloud corresponds directly to the
#' residual disparity space being tested. When multiple models are plotted, the
#' default behavior is to use shared axis limits so focal/background separation
#' can be compared directly across panels.
#'
#' @return For a single model, invisibly returns a list containing the fitted
#'   `mvgls` object, the residual matrix, the `prcomp` result, the PC scores, a
#'   logical focal-tip indicator, and the variance explained by each PC. For
#'   multiple models, invisibly returns a named list of that same structure, one
#'   entry per model.
#'
#' @examples
#' \dontrun{
#' ex <- focalDisparityExampleDataStandalone(seed = 2)
#'
#' pca_plot <- plotFocalResidualPCAStandalone(
#'   tree = ex$tree,
#'   trait_data = ex$trait_data,
#'   focal = ex$focal_tips,
#'   formula = cbind(y1, y2, y3) ~ size,
#'   model = "OU",
#'   method = "LL"
#' )
#'
#' head(pca_plot$scores)
#'
#' pca_panels <- plotFocalResidualPCAStandalone(
#'   tree = ex$tree,
#'   trait_data = ex$trait_data,
#'   focal = ex$focal_tips,
#'   formula = cbind(y1, y2, y3) ~ size,
#'   model = c("BM", "OU", "EB"),
#'   method = "LL"
#' )
#' }
.standalone_residual_pca_panel_layout <- function(n_panels) {
  if (n_panels <= 0L) {
    stop("n_panels must be >= 1.")
  }
  if (n_panels <= 3L) {
    return(c(1L, n_panels))
  }
  n_col <- ceiling(sqrt(n_panels))
  n_row <- ceiling(n_panels / n_col)
  c(n_row, n_col)
}

.standalone_expand_numeric_range <- function(values, frac = 0.08) {
  values <- as.numeric(values)
  values <- values[is.finite(values)]
  if (length(values) == 0L) {
    return(c(-1, 1))
  }
  out <- range(values)
  span <- diff(out)
  pad <- if (is.finite(span) && span > 0) {
    frac * span
  } else {
    max(1e-8, abs(out[1L]) * frac, 1)
  }
  c(out[1L] - pad, out[2L] + pad)
}

.standalone_convex_hull_indices <- function(coords) {
  coords <- as.matrix(coords)
  if (nrow(coords) < 3L) {
    return(integer())
  }
  unique_coords <- !duplicated(coords)
  coords <- coords[unique_coords, , drop = FALSE]
  if (nrow(coords) < 3L) {
    return(integer())
  }
  tryCatch(
    grDevices::chull(coords[, 1], coords[, 2]),
    error = function(e) integer()
  )
}

.standalone_plot_focal_residual_pca_single <- function(tree,
                                                       trait_data,
                                                       focal,
                                                       formula,
                                                       model,
                                                       method,
                                                       pc_x,
                                                       pc_y,
                                                       center,
                                                       scale.,
                                                       focal_col,
                                                       background_col,
                                                       focal_pch,
                                                       background_pch,
                                                       point_cex,
                                                       min_focal_tips,
                                                       extra_args) {
  prepared <- .standalone_prepare_focal_fit(
    tree = tree,
    trait_data = trait_data,
    focal = focal,
    formula = formula,
    model = model,
    method = method,
    min_focal_tips = min_focal_tips,
    extra_args = extra_args
  )

  pca <- stats::prcomp(
    prepared$residuals_matrix,
    center = center,
    scale. = scale.
  )
  scores <- pca$x
  n_pcs <- ncol(scores)
  if (pc_x > n_pcs || pc_y > n_pcs) {
    stop(
      "Requested PCs exceed the available components (n = ",
      n_pcs,
      ")."
    )
  }

  variance_explained <- (pca$sdev ^ 2) / sum(pca$sdev ^ 2)
  focal_indicator <- rownames(scores) %in% prepared$focal_tips

  list(
    fit = prepared$fit,
    residuals = prepared$residuals_matrix,
    pca = pca,
    scores = scores,
    focal_indicator = focal_indicator,
    focal_tips = prepared$focal_tips,
    variance_explained = variance_explained,
    formula_input = prepared$formula_input_chr,
    fit_formula = prepared$fit_formula_chr,
    fit_model = model,
    pc_x = pc_x,
    pc_y = pc_y
  )
}

.standalone_draw_focal_residual_pca_panel <- function(output,
                                                      main,
                                                      xlab,
                                                      ylab,
                                                      xlim,
                                                      ylim,
                                                      focal_col,
                                                      background_col,
                                                      focal_pch,
                                                      background_pch,
                                                      point_cex,
                                                      show_legend,
                                                      legend_position,
                                                      focal_label,
                                                      background_label,
                                                      show_centroids,
                                                      centroid_cex,
                                                      centroid_pch,
                                                      centroid_lwd,
                                                      show_hulls,
                                                      hull_alpha,
                                                      hull_lwd) {
  scores <- output$scores
  focal_indicator <- output$focal_indicator
  point_cols <- ifelse(focal_indicator, focal_col, background_col)
  point_pch <- ifelse(focal_indicator, focal_pch, background_pch)

  graphics::plot(
    scores[, output$pc_x],
    scores[, output$pc_y],
    col = point_cols,
    pch = point_pch,
    cex = point_cex,
    xlab = xlab,
    ylab = ylab,
    main = main,
    xlim = xlim,
    ylim = ylim
  )

  group_draw_specs <- list(
    list(mask = !focal_indicator, col = background_col),
    list(mask = focal_indicator, col = focal_col)
  )

  for (spec in group_draw_specs) {
    coords <- cbind(
      scores[spec$mask, output$pc_x, drop = TRUE],
      scores[spec$mask, output$pc_y, drop = TRUE]
    )
    if (isTRUE(show_hulls)) {
      hull_idx <- .standalone_convex_hull_indices(coords)
      if (length(hull_idx) >= 3L) {
        hull_coords <- coords[hull_idx, , drop = FALSE]
        graphics::polygon(
          hull_coords[, 1],
          hull_coords[, 2],
          border = spec$col,
          col = grDevices::adjustcolor(spec$col, alpha.f = hull_alpha),
          lwd = hull_lwd
        )
      }
    }
    if (isTRUE(show_centroids) && nrow(coords) > 0L) {
      ctr <- colMeans(coords)
      graphics::points(
        ctr[1],
        ctr[2],
        pch = centroid_pch,
        cex = centroid_cex,
        lwd = centroid_lwd,
        col = spec$col
      )
    }
  }

  graphics::points(
    scores[, output$pc_x],
    scores[, output$pc_y],
    col = point_cols,
    pch = point_pch,
    cex = point_cex
  )

  if (isTRUE(show_legend)) {
    graphics::legend(
      legend_position,
      legend = c(focal_label, background_label, "Centroids"),
      col = c(focal_col, background_col, "black"),
      pch = c(focal_pch, background_pch, centroid_pch),
      pt.cex = c(point_cex, point_cex, centroid_cex),
      bty = "n"
    )
  }
}

plotFocalResidualPCAStandalone <- function(tree,
                                           trait_data,
                                           focal,
                                           formula = "trait_data ~ 1",
                                           model = "BM",
                                           method = "PL-LOOCV",
                                           pc_x = 1L,
                                           pc_y = 2L,
                                           center = TRUE,
                                           scale. = FALSE,
                                           focal_col = "#c44e52",
                                           background_col = "#4c72b0",
                                           focal_pch = 19,
                                           background_pch = 1,
                                           point_cex = 1,
                                           show_legend = TRUE,
                                           legend_position = "topright",
                                           focal_label = "Focal clade",
                                           background_label = "Background",
                                           use_shared_limits = TRUE,
                                           show_centroids = TRUE,
                                           centroid_cex = 1.6,
                                           centroid_pch = 4,
                                           centroid_lwd = 2,
                                           show_hulls = TRUE,
                                           hull_alpha = 0.12,
                                           hull_lwd = 1.2,
                                           layout = NULL,
                                           main = NULL,
                                           xlab = NULL,
                                           ylab = NULL,
                                           min_focal_tips = 3L,
                                           ...) {
  checkFocalDisparityStandalonePackages()

  extra_args <- list(...)
  reserved_args <- intersect(
    c("formula", "tree", "model", "data", "method"),
    names(extra_args)
  )
  if (length(reserved_args) > 0L) {
    stop(
      "Do not pass reserved mvgls arguments via ...: ",
      paste(reserved_args, collapse = ", "),
      "."
    )
  }

  model <- match.arg(model, choices = c("BM", "OU", "EB"), several.ok = TRUE)
  model <- unique(model)
  pc_x <- as.integer(pc_x)
  pc_y <- as.integer(pc_y)
  if (length(pc_x) != 1L || is.na(pc_x) || pc_x < 1L) {
    stop("pc_x must be a single integer >= 1.")
  }
  if (length(pc_y) != 1L || is.na(pc_y) || pc_y < 1L) {
    stop("pc_y must be a single integer >= 1.")
  }
  if (identical(pc_x, pc_y)) {
    stop("pc_x and pc_y must refer to different principal components.")
  }

  n_models <- length(model)
  if (!is.null(layout)) {
    if (!is.numeric(layout) || length(layout) != 2L || any(!is.finite(layout)) || any(layout < 1)) {
      stop("layout must be a numeric vector of length 2 with positive values.")
    }
    layout <- as.integer(layout)
  } else if (n_models > 1L) {
    layout <- .standalone_residual_pca_panel_layout(n_models)
  }

  resolve_panel_arg <- function(arg, name) {
    if (is.null(arg)) {
      return(rep(list(NULL), n_models))
    }
    if (length(arg) == 1L) {
      return(rep(list(arg), n_models))
    }
    if (length(arg) != n_models) {
      stop(name, " must have length 1 or match the number of models.")
    }
    as.list(arg)
  }

  main_values <- resolve_panel_arg(main, "main")
  xlab_values <- resolve_panel_arg(xlab, "xlab")
  ylab_values <- resolve_panel_arg(ylab, "ylab")

  outputs <- vector("list", length = n_models)
  names(outputs) <- model

  for (i in seq_along(model)) {
    outputs[[i]] <- .standalone_plot_focal_residual_pca_single(
      tree = tree,
      trait_data = trait_data,
      focal = focal,
      formula = formula,
      model = model[i],
      method = method,
      pc_x = pc_x,
      pc_y = pc_y,
      center = center,
      scale. = scale.,
      focal_col = focal_col,
      background_col = background_col,
      focal_pch = focal_pch,
      background_pch = background_pch,
      point_cex = point_cex,
      min_focal_tips = min_focal_tips,
      extra_args = extra_args
    )
  }

  shared_x <- NULL
  shared_y <- NULL
  if (isTRUE(use_shared_limits) && n_models > 1L) {
    shared_x <- .standalone_expand_numeric_range(
      unlist(lapply(outputs, function(x) x$scores[, x$pc_x]))
    )
    shared_y <- .standalone_expand_numeric_range(
      unlist(lapply(outputs, function(x) x$scores[, x$pc_y]))
    )
  }

  if (n_models > 1L) {
    old_par <- graphics::par(no.readonly = TRUE)
    on.exit(graphics::par(old_par), add = TRUE)
    graphics::par(mfrow = layout)
  }

  for (i in seq_along(outputs)) {
    output_i <- outputs[[i]]
    main_i <- main_values[[i]]
    xlab_i <- xlab_values[[i]]
    ylab_i <- ylab_values[[i]]

    if (is.null(main_i)) {
      main_i <- paste0(output_i$fit_model, " residual morphospace")
    }
    if (is.null(xlab_i)) {
      xlab_i <- paste0(
        "PC",
        output_i$pc_x,
        " (",
        round(100 * output_i$variance_explained[output_i$pc_x], 1),
        "%)"
      )
    }
    if (is.null(ylab_i)) {
      ylab_i <- paste0(
        "PC",
        output_i$pc_y,
        " (",
        round(100 * output_i$variance_explained[output_i$pc_y], 1),
        "%)"
      )
    }

    xlim_i <- if (!is.null(shared_x)) {
      shared_x
    } else {
      .standalone_expand_numeric_range(output_i$scores[, output_i$pc_x])
    }
    ylim_i <- if (!is.null(shared_y)) {
      shared_y
    } else {
      .standalone_expand_numeric_range(output_i$scores[, output_i$pc_y])
    }

    .standalone_draw_focal_residual_pca_panel(
      output = output_i,
      main = main_i,
      xlab = xlab_i,
      ylab = ylab_i,
      xlim = xlim_i,
      ylim = ylim_i,
      focal_col = focal_col,
      background_col = background_col,
      focal_pch = focal_pch,
      background_pch = background_pch,
      point_cex = point_cex,
      show_legend = isTRUE(show_legend) && (n_models == 1L || i == 1L),
      legend_position = legend_position,
      focal_label = focal_label,
      background_label = background_label,
      show_centroids = show_centroids,
      centroid_cex = centroid_cex,
      centroid_pch = centroid_pch,
      centroid_lwd = centroid_lwd,
      show_hulls = show_hulls,
      hull_alpha = hull_alpha,
      hull_lwd = hull_lwd
    )
  }

  invisible(
    if (n_models == 1L) {
      outputs[[1L]]
    } else {
      outputs
    }
  )
}

#' Plot Post-hoc Subtree Covariance and Correlation Heatmaps
#'
#' @description
#' Standalone counterpart of `plotSubtreeCovarianceHeatmaps()`. It fits post-hoc
#' `mvgls` models on the focal and/or background pruned trees, extracts the
#' inferred residual variance-covariance (`sigma`) matrices, converts them to
#' correlation matrices, and draws clustered heatmaps with dendrograms.
#'
#' @param tree A rooted phylogeny of class `phylo` or coercible with
#'   `ape::as.phylo()`.
#' @param trait_data A numeric matrix or data frame with row names matching tip
#'   labels in `tree`.
#' @param focal Focal definition. Supply either a character vector of tip
#'   labels, a logical selector of length `ape::Ntip(tree)`, or a single
#'   internal node number.
#' @param formula Formula passed to `mvMORPH::mvgls()`. Supports the same named,
#'   response-only, and legacy indexed styles as
#'   `testFocalDisparityStandalone()`.
#' @param model Character fit-model code or vector of fit-model codes.
#'   Supported values are `"BM"`, `"OU"`, and `"EB"`.
#' @param method Character fitting method passed to `mvMORPH::mvgls()`.
#' @param subsets Which post-hoc subsets to fit. One or both of `"focal"` and
#'   `"background"`. The background subset is the pruned tree obtained after
#'   removing focal tips.
#' @param matrix_type Which matrices to plot. One or both of `"covariance"` and
#'   `"correlation"`.
#' @param min_subtree_tips Minimum number of tips required for each requested
#'   subtree fit.
#' @param draw Logical; if `TRUE`, draw the requested heatmaps. If multiple
#'   model/subset/matrix combinations are requested, they are drawn in
#'   sequence. On interactive devices, the function asks before advancing to
#'   the next page.
#' @param palette Color palette used for all heatmaps.
#' @param correlation_zlim Numeric length-2 vector passed as `zlim` when
#'   plotting correlation matrices.
#' @param covariance_zlim Optional numeric length-2 vector passed as `zlim`
#'   when plotting covariance matrices. Defaults to `NULL`.
#' @param cexRow Character expansion for row labels in the heatmaps.
#' @param cexCol Character expansion for column labels in the heatmaps.
#' @param margins Margins passed to `stats::heatmap()`.
#' @param ... Additional arguments passed to `mvMORPH::mvgls()`.
#'
#' @details
#' Clustering is performed on the inferred correlation matrix for each fitted
#' subtree, and the same dendrogram ordering is then reused for both the
#' covariance and correlation heatmaps from that fit so the two panels remain
#' directly comparable. Each heatmap is annotated with the fitted subtree size
#' and a compact summary of covariance magnitude and correlation structure, and
#' numeric matrix values are overlaid directly on the cells for quick reading.
#' When multiple covariance heatmaps are drawn in one call and
#' `covariance_zlim = NULL`, a shared symmetric color scale is computed across
#' all requested covariance matrices.
#'
#' @return Invisibly returns an object of class
#'   `bifrost_subtree_covariance_heatmaps_standalone`. The object behaves like a
#'   nested named list indexed by model and subset, so existing access patterns
#'   such as `x$OU$focal$correlation` continue to work. Each leaf contains the
#'   fitted `mvgls` object, the pruned tree, the tip set, the inferred
#'   covariance matrix, the derived correlation matrix, the dendrogram used for
#'   plotting, and a one-row summary table. A model-by-subset summary table and
#'   a focal-vs-background contrast table are stored on the object and returned
#'   by `summary()`.
#'
#' @examples
#' \dontrun{
#' ex <- focalDisparityExampleDataStandalone(seed = 2)
#'
#' subtree_mats <- plotSubtreeCovarianceHeatmapsStandalone(
#'   tree = ex$tree,
#'   trait_data = ex$trait_data,
#'   focal = ex$focal_tips,
#'   formula = cbind(y1, y2, y3) ~ size,
#'   model = c("BM", "OU"),
#'   subsets = c("focal", "background"),
#'   matrix_type = c("covariance", "correlation"),
#'   method = "LL"
#' )
#'
#' print(subtree_mats)
#' summary(subtree_mats)$summary_table
#'
#' subtree_mats$OU$focal$correlation
#' }
plotSubtreeCovarianceHeatmapsStandalone <- function(tree,
                                                    trait_data,
                                                    focal,
                                                    formula = "trait_data ~ 1",
                                                    model = "BM",
                                                    method = "PL-LOOCV",
                                                    subsets = c("focal", "background"),
                                                    matrix_type = c("covariance", "correlation"),
                                                    min_subtree_tips = 3L,
                                                    draw = TRUE,
                                                    palette = grDevices::colorRampPalette(
                                                      c("#3b4cc0", "#f7f7f7", "#b40426")
                                                    )(101),
                                                    correlation_zlim = c(-1, 1),
                                                    covariance_zlim = NULL,
                                                    cexRow = 0.7,
                                                    cexCol = 0.7,
                                                    margins = c(8, 8),
                                                    ...) {
  checkFocalDisparityStandalonePackages()

  extra_args <- list(...)
  reserved_args <- intersect(
    c("formula", "tree", "model", "data", "method"),
    names(extra_args)
  )
  if (length(reserved_args) > 0L) {
    stop(
      "Do not pass reserved mvgls arguments via ...: ",
      paste(reserved_args, collapse = ", "),
      "."
    )
  }

  model <- match.arg(model, choices = c("BM", "OU", "EB"), several.ok = TRUE)
  model <- unique(model)
  subsets <- match.arg(subsets, choices = c("focal", "background"), several.ok = TRUE)
  subsets <- unique(subsets)
  matrix_type <- match.arg(
    matrix_type,
    choices = c("covariance", "correlation"),
    several.ok = TRUE
  )
  matrix_type <- unique(matrix_type)

  if (!is.numeric(min_subtree_tips) ||
      length(min_subtree_tips) != 1L ||
      is.na(min_subtree_tips) ||
      min_subtree_tips < 3L) {
    stop("min_subtree_tips must be a single integer >= 3.")
  }
  min_subtree_tips <- as.integer(min_subtree_tips)

  aligned <- .standalone_align_inputs(
    tree = tree,
    trait_data = trait_data,
    focal = focal,
    min_focal_tips = min_subtree_tips
  )
  aligned_tree <- aligned$tree
  aligned_data <- aligned$trait_data
  focal_tips <- aligned$focal_tips
  background_tips <- setdiff(aligned_tree$tip.label, focal_tips)

  if ("background" %in% subsets && length(background_tips) < min_subtree_tips) {
    stop(
      "background subset must contain at least ",
      min_subtree_tips,
      " tips after alignment; found ",
      length(background_tips),
      "."
    )
  }

  ask_enabled <- FALSE
  if (isTRUE(draw) && interactive() && length(model) * length(subsets) * length(matrix_type) > 1L) {
    ask_enabled <- grDevices::devAskNewPage(TRUE)
    on.exit(grDevices::devAskNewPage(ask_enabled), add = TRUE)
  }

  outputs <- vector("list", length = length(model))
  names(outputs) <- model
  summary_rows <- list()
  summary_index <- 1L
  formula_input_chr <- if (inherits(formula, "formula")) {
    paste(deparse(formula, width.cutoff = 500), collapse = " ")
  } else {
    as.character(formula)[1L]
  }

  for (model_i in model) {
    model_out <- vector("list", length = length(subsets))
    names(model_out) <- subsets

    for (subset_i in subsets) {
      tip_set <- if (identical(subset_i, "focal")) focal_tips else background_tips
      prepared <- .standalone_prepare_subtree_fit(
        tree = aligned_tree,
        trait_data = aligned_data,
        tips = tip_set,
        formula = formula,
        model = model_i,
        method = method,
        min_subtree_tips = min_subtree_tips,
        extra_args = extra_args,
        subset_label = subset_i
      )

      sigma_matrix <- .standalone_extract_sigma_matrix(prepared$fit)
      corr_matrix <- .standalone_sigma_to_correlation(sigma_matrix)
      rownames(sigma_matrix) <- colnames(sigma_matrix) <- prepared$response_names
      rownames(corr_matrix) <- colnames(corr_matrix) <- prepared$response_names
      dendrogram <- .standalone_correlation_dendrogram(corr_matrix)
      matrix_summary <- .standalone_summarize_subtree_matrices(
        covariance = sigma_matrix,
        correlation = corr_matrix,
        fit_model = model_i,
        subset = subset_i,
        tip_labels = prepared$subset_tips
      )

      model_out[[subset_i]] <- list(
        fit = prepared$fit,
        tree = prepared$tree,
        tip_labels = prepared$subset_tips,
        covariance = sigma_matrix,
        correlation = corr_matrix,
        dendrogram = dendrogram,
        formula_input = prepared$formula_input_chr,
        fit_formula = prepared$fit_formula_chr,
        fit_model = model_i,
        subset = subset_i,
        summary = matrix_summary
      )
      summary_rows[[summary_index]] <- matrix_summary
      summary_index <- summary_index + 1L

    }

    outputs[[model_i]] <- model_out
  }

  summary_table <- do.call(rbind, summary_rows)
  rownames(summary_table) <- NULL
  contrast_table <- .standalone_build_subtree_contrast_table(summary_table)

  attr(outputs, "summary_table") <- summary_table
  attr(outputs, "contrast_table") <- contrast_table
  attr(outputs, "formula_input") <- formula_input_chr
  attr(outputs, "models") <- model
  attr(outputs, "subsets") <- subsets
  attr(outputs, "matrix_type") <- matrix_type
  class(outputs) <- c("bifrost_subtree_covariance_heatmaps_standalone", class(outputs))

  resolved_covariance_zlim <- covariance_zlim
  if (is.null(resolved_covariance_zlim) && "covariance" %in% matrix_type) {
    covariance_values <- unlist(
      lapply(outputs, function(model_out) {
        unlist(lapply(model_out, function(x) as.numeric(x$covariance)))
      }),
      use.names = FALSE
    )
    covariance_values <- covariance_values[is.finite(covariance_values)]
    if (length(covariance_values) > 0L) {
      max_abs <- max(abs(covariance_values))
      resolved_covariance_zlim <- c(-max_abs, max_abs)
    }
  }

  if (isTRUE(draw)) {
    for (model_i in names(outputs)) {
      for (subset_i in names(outputs[[model_i]])) {
        result_i <- outputs[[model_i]][[subset_i]]
        summary_i <- result_i$summary
        summary_text <- sprintf(
          "tips=%d | trace=%.2f | logdet=%.2f | evenness=%.2f | mean|r|=%.2f",
          summary_i$n_tips,
          summary_i$trace_cov,
          summary_i$log_det_cov,
          summary_i$eigenvalue_evenness,
          summary_i$mean_abs_correlation
        )

        for (matrix_name in matrix_type) {
          matrix_to_plot <- result_i[[matrix_name]]
          zlim <- if (identical(matrix_name, "correlation")) {
            correlation_zlim
          } else {
            resolved_covariance_zlim
          }
          .standalone_plot_matrix_heatmap(
            matrix_data = matrix_to_plot,
            main = paste0(
              model_i,
              " / ",
              if (identical(subset_i, "focal")) "Focal" else "Background",
              " / ",
              if (identical(matrix_name, "correlation")) "Correlation" else "VCV"
            ),
            palette = palette,
            row_dendrogram = result_i$dendrogram,
            zlim = zlim,
            cexRow = cexRow,
            cexCol = cexCol,
            margins = margins,
            summary_text = summary_text
          )
        }
      }
    }
  }

  invisible(outputs)
}

.standalone_draw_focal_grid_summary <- function(summary_df,
                                                stat = c("ses", "p_upper", "p_lower", "p_two_tailed"),
                                                main = NULL,
                                                show_text = TRUE,
                                                p_cutoff = 0.05,
                                                digits = 2) {
  stat <- match.arg(stat)
  metrics <- unique(summary_df$metric)
  models <- unique(summary_df$model)
  value_matrix <- matrix(
    NA_real_,
    nrow = length(metrics),
    ncol = length(models),
    dimnames = list(metrics, models)
  )
  label_matrix <- matrix(
    "",
    nrow = length(metrics),
    ncol = length(models),
    dimnames = list(metrics, models)
  )
  direction_matrix <- matrix(
    "",
    nrow = length(metrics),
    ncol = length(models),
    dimnames = list(metrics, models)
  )

  for (i in seq_len(nrow(summary_df))) {
    row_i <- match(summary_df$metric[i], metrics)
    col_i <- match(summary_df$model[i], models)
    value_matrix[row_i, col_i] <- summary_df[[stat]][i]
    if (identical(stat, "ses")) {
      label_matrix[row_i, col_i] <- formatC(summary_df$ses[i], format = "f", digits = digits)
      direction_matrix[row_i, col_i] <- if (summary_df$p_upper[i] <= p_cutoff) {
        "\u2191"
      } else if (summary_df$p_lower[i] <= p_cutoff) {
        "\u2193"
      } else {
        ""
      }
    } else {
      label_matrix[row_i, col_i] <- formatC(summary_df[[stat]][i], format = "f", digits = digits)
    }
  }

  if (is.null(main)) {
    main <- if (identical(stat, "ses")) {
      "Focal disparity grid summary (SES)"
    } else {
      paste0("Focal disparity grid summary (", stat, ")")
    }
  }

  if (identical(stat, "ses")) {
    finite_values <- abs(value_matrix[is.finite(value_matrix)])
    max_abs <- if (length(finite_values) > 0L) max(finite_values) else 1
    zlim <- c(-max_abs, max_abs)
    palette <- grDevices::colorRampPalette(c("#2166ac", "#f7f7f7", "#b2182b"))(201)
    key_values <- seq(zlim[1], zlim[2], length.out = length(palette))
    key_label <- "SES"
  } else {
    finite_values <- value_matrix[is.finite(value_matrix)]
    zlim <- if (length(finite_values) > 0L) range(finite_values) else c(0, 1)
    palette <- grDevices::colorRampPalette(c("#f7fbff", "#6baed6", "#08306b"))(201)
    key_values <- seq(zlim[1], zlim[2], length.out = length(palette))
    key_label <- stat
  }
  if (!all(is.finite(zlim))) {
    zlim <- c(0, 1)
    key_values <- seq(zlim[1], zlim[2], length.out = length(palette))
  }

  layout(matrix(c(1, 2), nrow = 1L), widths = c(5, 1))

  plot_matrix <- value_matrix[nrow(value_matrix):1, , drop = FALSE]
  metric_margin <- max(8, max(nchar(metrics), na.rm = TRUE) * 0.6)
  graphics::par(mar = c(metric_margin, 10, 4, 2))
  graphics::image(
    x = seq_len(ncol(plot_matrix)),
    y = seq_len(nrow(plot_matrix)),
    z = t(plot_matrix),
    col = palette,
    zlim = zlim,
    axes = FALSE,
    xlab = "",
    ylab = "",
    main = main
  )
  graphics::axis(1, at = seq_along(models), labels = models, las = 1)
  graphics::axis(2, at = seq_along(metrics), labels = rev(metrics), las = 2)
  graphics::box()

  if (isTRUE(show_text)) {
    for (row_i in seq_along(metrics)) {
      for (col_i in seq_along(models)) {
        plot_row <- length(metrics) - row_i + 1L
        label_i <- label_matrix[row_i, col_i]
        dir_i <- direction_matrix[row_i, col_i]
        if (!identical(label_i, "")) {
          graphics::text(col_i, plot_row + 0.12, labels = label_i, cex = 0.8)
        }
        if (!identical(dir_i, "")) {
          graphics::text(col_i, plot_row - 0.22, labels = dir_i, cex = 1.1)
        }
      }
    }
  }

  graphics::mtext(
    if (identical(stat, "ses")) {
      "Cell text = SES; arrows mark p_upper <= cutoff (up) or p_lower <= cutoff (down)"
    } else {
      "Cell text shows the plotted statistic"
    },
    side = 1,
    line = 6.5,
    cex = 0.75
  )

  graphics::par(mar = c(metric_margin, 1, 4, 4))
  graphics::plot.new()
  graphics::plot.window(xlim = c(0, 1), ylim = range(key_values))
  for (i in seq_len(length(palette) - 1L)) {
    graphics::rect(
      xleft = 0,
      ybottom = key_values[i],
      xright = 1,
      ytop = key_values[i + 1L],
      col = palette[i],
      border = NA
    )
  }
  graphics::axis(4, las = 2)
  graphics::mtext(key_label, side = 4, line = 2)
}

#' Run a Full Focal Disparity Grid Across Models and Metrics
#'
#' @description
#' Standalone counterpart of `runFocalDisparityGrid()`. It evaluates
#' `testFocalDisparityStandalone()` across all requested combinations of
#' supported single-regime models and focal disparity metrics for a shared data
#' bundle.
#'
#' @param data_bundle A list with components `tree`, `data`, and `focal_tips`.
#'   `data` should be a matrix or data frame with row names matching tree tip
#'   labels.
#' @param berv_data Backward-compatible alias for `data_bundle`.
#' @param predictor_col Integer index of the predictor column used on the right
#'   side of the generated `mvgls` formula.
#' @param response_cols Integer vector of response columns used on the left side
#'   of the generated `cbind(...)` formula.
#' @param metrics Character vector of metric names passed to
#'   `testFocalDisparityStandalone()`.
#' @param models Character vector of supported fit/simulation models passed to
#'   `testFocalDisparityStandalone()`.
#' @param nsim Integer number of bootstrap replicates per model-metric
#'   combination.
#' @param method Character fitting method passed to `mvMORPH::mvgls()`.
#' @param workers Integer number of bootstrap workers.
#' @param seed Integer seed passed through to each grid cell run.
#' @param future_plan Future backend used for each grid cell. If `NULL`, the
#'   same defaulting logic as `testFocalDisparityStandalone()` is used.
#' @param show_progress Logical; if `TRUE`, show per-run bootstrap progress.
#' @param min_focal_tips Minimum number of focal tips required after alignment.
#' @param output_dir Optional directory for saving a CSV summary, an `.rds`
#'   object containing the individual results, and one PNG plot per
#'   model-metric combination. If `NULL`, no files are written.
#' @param plot_width Plot width in inches for saved PNG outputs.
#' @param plot_height Plot height in inches for saved PNG outputs.
#' @param plot_dpi Plot resolution for saved PNG outputs.
#' @param ... Additional arguments passed to `testFocalDisparityStandalone()`
#'   and onward to `mvMORPH::mvgls()`.
#'
#' @details
#' The generated formula has the form
#' `cbind(response_1, response_2, ...) ~ predictor`, where the predictor and
#' responses are selected from `data_bundle$data` using `predictor_col` and
#' `response_cols`.
#'
#' @return An object of class `bifrost_focal_disparity_grid_standalone`
#'   containing the constructed formula, the chosen predictor and responses, a
#'   summary data frame ordered by upper-tail p-value, the raw list of
#'   `testFocalDisparityStandalone()` result objects, and the normalized output
#'   directory path when files are written.
#'
#' @examples
#' \dontrun{
#' ex <- focalDisparityExampleDataStandalone(seed = 2)
#'
#' grid <- runFocalDisparityGridStandalone(
#'   data_bundle = list(
#'     tree = ex$tree,
#'     data = ex$trait_data,
#'     focal_tips = ex$focal_tips
#'   ),
#'   predictor_col = 4,
#'   response_cols = 1:3,
#'   nsim = 25,
#'   models = c("BM", "OU"),
#'   metrics = c("centroid_msd", "mean_pairwise_sqdist"),
#'   workers = 1,
#'   future_plan = "sequential",
#'   show_progress = FALSE
#' )
#'
#' grid$summary
#' }
runFocalDisparityGridStandalone <- function(data_bundle = NULL,
                                            berv_data = NULL,
                                            predictor_col = 1L,
                                            response_cols = 2:12,
                                            metrics = c(
                                              "centroid_msd",
                                              "trace_cov",
                                              "mean_pairwise_sqdist",
                                              "log_det_cov",
                                              "max_eigenvalue",
                                              "eigenvalue_evenness"
                                            ),
                                            models = c("BM", "OU", "EB"),
                                            nsim = 1000L,
                                            method = "LL",
                                            workers = 1L,
                                            seed = 2L,
                                            future_plan = NULL,
                                            show_progress = TRUE,
                                            min_focal_tips = 3L,
                                            output_dir = NULL,
                                            plot_width = 7,
                                            plot_height = 5,
                                            plot_dpi = 150,
                                            ...) {
  checkFocalDisparityStandalonePackages()

  if (is.null(data_bundle)) {
    data_bundle <- berv_data
  }

  if (!is.list(data_bundle) ||
      !all(c("tree", "data", "focal_tips") %in% names(data_bundle))) {
    stop("`data_bundle` must be a list with elements: tree, data, focal_tips.")
  }

  trait_data <- as.data.frame(
    data_bundle$data,
    check.names = FALSE,
    stringsAsFactors = FALSE
  )

  if (is.null(rownames(trait_data))) {
    stop("`data_bundle$data` must have row names matching tree tip labels.")
  }

  n_cols <- ncol(trait_data)
  if (length(predictor_col) != 1L ||
      is.na(predictor_col) ||
      predictor_col < 1L ||
      predictor_col > n_cols) {
    stop("`predictor_col` must index one existing column in `data_bundle$data`.")
  }

  if (length(response_cols) < 1L ||
      any(is.na(response_cols)) ||
      any(response_cols < 1L) ||
      any(response_cols > n_cols)) {
    stop("`response_cols` must index one or more existing columns in `data_bundle$data`.")
  }

  response_cols <- unique(as.integer(response_cols))
  predictor_col <- as.integer(predictor_col)
  predictor <- colnames(trait_data)[predictor_col]
  responses <- colnames(trait_data)[response_cols]

  if (predictor %in% responses) {
    stop("Predictor column must not also be included in the response columns.")
  }

  formula_text <- paste0(
    "cbind(",
    paste(responses, collapse = ", "),
    ") ~ ",
    predictor
  )
  form <- stats::as.formula(formula_text)

  if (!is.null(output_dir)) {
    dir.create(output_dir, recursive = TRUE, showWarnings = FALSE)
  }

  grid <- expand.grid(
    model = models,
    metric = metrics,
    stringsAsFactors = FALSE,
    KEEP.OUT.ATTRS = FALSE
  )

  results <- vector("list", length = nrow(grid))
  summary_rows <- vector("list", length = nrow(grid))

  for (i in seq_len(nrow(grid))) {
    model_i <- grid$model[i]
    metric_i <- grid$metric[i]

    message(sprintf("[%d/%d] model=%s metric=%s", i, nrow(grid), model_i, metric_i))

    result_i <- testFocalDisparityStandalone(
      tree = data_bundle$tree,
      trait_data = trait_data,
      focal = data_bundle$focal_tips,
      formula = form,
      metric = metric_i,
      nsim = nsim,
      model = model_i,
      method = method,
      workers = workers,
      seed = seed,
      future_plan = future_plan,
      show_progress = show_progress,
      min_focal_tips = min_focal_tips,
      ...
    )

    results[[i]] <- result_i
    summary_rows[[i]] <- data.frame(
      model = model_i,
      simulation_model = result_i$simulation_model,
      metric = metric_i,
      focal_tip_count = length(result_i$focal_tips),
      nsim = result_i$nsim,
      observed = result_i$observed_statistic,
      null_mean = result_i$null_mean,
      null_sd = result_i$null_sd,
      ses = result_i$SES,
      p_upper = result_i$p_upper,
      p_lower = result_i$p_lower,
      p_two_tailed = result_i$p_two_tailed,
      formula_input = result_i$formula_input,
      fit_formula = result_i$fit_formula,
      stringsAsFactors = FALSE
    )

    if (!is.null(output_dir)) {
      plot_path <- file.path(
        output_dir,
        sprintf(
          "focal-disparity__model-%s__metric-%s.png",
          tolower(model_i),
          metric_i
        )
      )

      grDevices::png(
        filename = plot_path,
        width = plot_width,
        height = plot_height,
        units = "in",
        res = plot_dpi
      )
      plot(
        result_i,
        main = sprintf("Focal disparity: %s / %s", model_i, metric_i),
        col = "#dceefa",
        border = "#5b7fa3"
      )
      grDevices::dev.off()
    }
  }

  summary_df <- do.call(rbind, summary_rows)
  ordered <- summary_df[order(summary_df$p_upper, summary_df$model, summary_df$metric), , drop = FALSE]
  rownames(ordered) <- NULL

  normalized_output_dir <- NULL
  grid_out <- list(
    formula = form,
    predictor = predictor,
    responses = responses,
    summary = ordered,
    results = results,
    output_dir = NULL
  )
  class(grid_out) <- c("bifrost_focal_disparity_grid_standalone", class(grid_out))

  if (!is.null(output_dir)) {
    summary_path <- file.path(output_dir, "focal-disparity-grid-summary.csv")
    rds_path <- file.path(output_dir, "focal-disparity-grid-results.rds")
    utils::write.csv(ordered, file = summary_path, row.names = FALSE)
    saveRDS(results, file = rds_path)
    normalized_output_dir <- normalizePath(output_dir, winslash = "/", mustWork = TRUE)
    grid_out$output_dir <- normalized_output_dir

    summary_plot_path <- file.path(output_dir, "focal-disparity-grid-summary.png")
    grDevices::png(
      filename = summary_plot_path,
      width = max(8, 2 + length(models) * 2),
      height = max(6, 2 + length(metrics) * 0.7),
      units = "in",
      res = plot_dpi
    )
    old_par <- graphics::par(no.readonly = TRUE)
    plot(grid_out)
    graphics::par(old_par)
    grDevices::dev.off()
  }

  invisible(grid_out)
}

#' Print method for standalone focal disparity grid runs
#'
#' @param x A `bifrost_focal_disparity_grid_standalone` object returned by
#'   `runFocalDisparityGridStandalone()`.
#' @param top_n Number of top-ranked rows from `x$summary` to display.
#' @param ... Unused (S3 compatibility).
#'
#' @return Invisibly returns `x`.
print.bifrost_focal_disparity_grid_standalone <- function(x, top_n = 6L, ...) {
  top_n <- max(1L, as.integer(top_n))
  cat("Standalone Focal Disparity Grid\n")
  cat("===============================\n\n")
  cat("Formula\n")
  cat("  ", paste(deparse(x$formula, width.cutoff = 500), collapse = " "), "\n", sep = "")
  cat("  Predictor: ", x$predictor, "\n", sep = "")
  cat("  Responses: ", paste(x$responses, collapse = ", "), "\n\n", sep = "")

  cat("Grid\n")
  cat("  Models: ", paste(unique(x$summary$model), collapse = ", "), "\n", sep = "")
  cat("  Metrics: ", paste(unique(x$summary$metric), collapse = ", "), "\n", sep = "")
  cat("  Cells: ", nrow(x$summary), "\n\n", sep = "")

  cat("Top Results\n")
  print(utils::head(
    x$summary[, c("model", "metric", "observed", "null_mean", "ses", "p_upper", "p_lower"), drop = FALSE],
    top_n
  ), row.names = FALSE)

  invisible(x)
}

#' Plot method for standalone focal disparity grid runs
#'
#' @param x A `bifrost_focal_disparity_grid_standalone` object returned by
#'   `runFocalDisparityGridStandalone()`.
#' @param stat Which summary statistic to visualize. One of `"ses"`,
#'   `"p_upper"`, `"p_lower"`, or `"p_two_tailed"`.
#' @param main Plot title.
#' @param show_text Logical; if `TRUE`, overlay cell text.
#' @param p_cutoff P-value threshold used for directional arrows on the SES
#'   plot.
#' @param digits Digits used for overlaid cell labels.
#' @param ... Unused (S3 compatibility).
#'
#' @return Invisibly returns `x`.
plot.bifrost_focal_disparity_grid_standalone <- function(x,
                                                         stat = c("ses", "p_upper", "p_lower", "p_two_tailed"),
                                                         main = NULL,
                                                         show_text = TRUE,
                                                         p_cutoff = 0.05,
                                                         digits = 2,
                                                         ...) {
  old_par <- graphics::par(no.readonly = TRUE)
  on.exit(graphics::par(old_par), add = TRUE)
  .standalone_draw_focal_grid_summary(
    summary_df = x$summary,
    stat = match.arg(stat),
    main = main,
    show_text = show_text,
    p_cutoff = p_cutoff,
    digits = digits
  )
  invisible(x)
}

#' Print method for standalone subtree covariance heatmap summaries
#'
#' @param x A `bifrost_subtree_covariance_heatmaps_standalone` object returned
#'   by `plotSubtreeCovarianceHeatmapsStandalone()`.
#' @param ... Unused (S3 compatibility).
#'
#' @return Invisibly returns `x`.
print.bifrost_subtree_covariance_heatmaps_standalone <- function(x, ...) {
  summary_table <- attr(x, "summary_table")
  contrast_table <- attr(x, "contrast_table")

  cat("Standalone Subtree Covariance Heatmaps\n")
  cat("======================================\n\n")
  cat("Request\n")
  cat("  Formula: ", attr(x, "formula_input"), "\n", sep = "")
  cat("  Models: ", paste(attr(x, "models"), collapse = ", "), "\n", sep = "")
  cat("  Subsets: ", paste(attr(x, "subsets"), collapse = ", "), "\n", sep = "")
  cat("  Heatmaps: ", paste(attr(x, "matrix_type"), collapse = ", "), "\n\n", sep = "")

  if (!is.null(summary_table) && nrow(summary_table) > 0L) {
    cat("Summary\n")
    .standalone_print_subtree_covariance_table(
      summary_table[, c(
        "model",
        "subset",
        "n_tips",
        "n_traits",
        "trace_cov",
        "log_det_cov",
        "max_eigenvalue",
        "eigenvalue_evenness",
        "mean_abs_correlation",
        "max_abs_correlation"
      ), drop = FALSE]
    )
  }

  if (!is.null(contrast_table) && nrow(contrast_table) > 0L) {
    cat("\nFocal vs Background Contrasts\n")
    .standalone_print_subtree_covariance_table(
      contrast_table[, c(
        "model",
        "trace_cov_ratio",
        "log_det_cov_diff",
        "max_eigenvalue_ratio",
        "lead_eigenvalue_prop_diff",
        "eigenvalue_evenness_diff",
        "mean_abs_correlation_diff"
      ), drop = FALSE]
    )
  }

  invisible(x)
}

#' Summary method for standalone subtree covariance heatmap summaries
#'
#' @param object A `bifrost_subtree_covariance_heatmaps_standalone` object
#'   returned by `plotSubtreeCovarianceHeatmapsStandalone()`.
#' @param ... Unused (S3 compatibility).
#'
#' @return A list with `summary_table` and `contrast_table` data frames.
summary.bifrost_subtree_covariance_heatmaps_standalone <- function(object, ...) {
  list(
    summary_table = attr(object, "summary_table"),
    contrast_table = attr(object, "contrast_table")
  )
}

#' Print method for standalone focal disparity bootstrap tests
#'
#' @param x A `bifrost_focal_disparity_test_standalone` object returned by
#'   `testFocalDisparityStandalone()`.
#' @param ... Unused (S3 compatibility).
#'
#' @return Invisibly returns `x`.
print.bifrost_focal_disparity_test_standalone <- function(x, ...) {
  cat("Standalone Focal Disparity Test\n")
  cat("================================\n\n")
  cat("Model\n")
  cat("  Input formula: ", x$formula_input, "\n", sep = "")
  if (!identical(x$formula_input, x$fit_formula)) {
    cat("  Fit formula: ", x$fit_formula, "\n", sep = "")
  }
  cat("  Fit model: ", x$fit_model, "\n", sep = "")
  cat("  Fit method: ", x$method, "\n", sep = "")
  cat("  Bootstrap model: ", x$fit_model, "\n", sep = "")
  cat("  Simulation code: ", x$simulation_model, "\n\n", sep = "")

  cat("Focal Set\n")
  cat("  Tips: ", length(x$focal_tips), "\n", sep = "")
  cat("  Metric: ", x$metric, "\n", sep = "")
  cat("  Simulations: ", x$nsim, "\n\n", sep = "")

  cat("Results\n")
  cat("  Observed: ", formatC(x$observed_statistic, format = "f", digits = 6), "\n", sep = "")
  cat("  Null mean: ", formatC(x$null_mean, format = "f", digits = 6), "\n", sep = "")
  cat("  Null sd: ", formatC(x$null_sd, format = "f", digits = 6), "\n", sep = "")
  cat("  SES: ", formatC(x$SES, format = "f", digits = 6), "\n", sep = "")
  cat("  Upper-tail p: ", formatC(x$p_upper, format = "f", digits = 6), "\n", sep = "")
  cat("  Lower-tail p: ", formatC(x$p_lower, format = "f", digits = 6), "\n", sep = "")
  cat("  Two-tailed p: ", formatC(x$p_two_tailed, format = "f", digits = 6), "\n", sep = "")

  invisible(x)
}

#' Plot method for standalone focal disparity bootstrap tests
#'
#' @param x A `bifrost_focal_disparity_test_standalone` object returned by
#'   `testFocalDisparityStandalone()`.
#' @param breaks Histogram break specification passed to `graphics::hist()`.
#' @param main Plot title. Defaults to `"Null Distribution of Focal Disparity"`.
#' @param xlab X-axis label. Defaults to a metric-aware label.
#' @param ... Additional graphical parameters passed to `graphics::hist()`.
#'
#' @details
#' The x-axis is expanded automatically when needed so the observed disparity
#' reference line remains visible. If `xlim` is supplied through `...`, it is
#' widened only when necessary to include the observed value.
#'
#' @return Invisibly returns `x`.
plot.bifrost_focal_disparity_test_standalone <- function(x,
                                                         breaks = 30,
                                                         main = "Null Distribution of Focal Disparity",
                                                         xlab = NULL,
                                                         ...) {
  dots <- list(...)

  if (is.null(xlab)) {
    xlab <- if (!is.null(x$metric) && !identical(x$metric, "user_function")) {
      paste0("Bootstrap metric: ", x$metric)
    } else {
      "Bootstrap statistic"
    }
  }

  hist_template <- graphics::hist(
    x$null_statistics,
    breaks = breaks,
    plot = FALSE
  )

  xlim <- if ("xlim" %in% names(dots)) {
    range(as.numeric(dots$xlim), finite = TRUE)
  } else {
    range(hist_template$breaks, finite = TRUE)
  }

  if (!all(is.finite(xlim)) || length(xlim) != 2L) {
    stop("xlim must contain two finite numeric values.")
  }

  observed <- as.numeric(x$observed_statistic)
  if (observed <= xlim[1L] || observed >= xlim[2L]) {
    xlim <- range(c(xlim, observed), finite = TRUE)
    span <- diff(xlim)
    pad <- if (is.finite(span) && span > 0) {
      0.04 * span
    } else {
      max(1e-8, abs(observed) * 0.04, 1)
    }
    xlim <- c(xlim[1L] - pad, xlim[2L] + pad)
  }

  dots$xlim <- xlim
  if (is.null(dots$sub)) {
    dots$sub <- paste0(
      "Observed = ", formatC(x$observed_statistic, format = "f", digits = 3),
      " | Null mean = ", formatC(x$null_mean, format = "f", digits = 3),
      " | SES = ", formatC(x$SES, format = "f", digits = 2),
      " | p_upper = ", formatC(x$p_upper, format = "f", digits = 3),
      " | p_lower = ", formatC(x$p_lower, format = "f", digits = 3)
    )
  }

  do.call(
    graphics::hist,
    c(
      list(
        x = x$null_statistics,
        breaks = hist_template$breaks,
        main = main,
        xlab = xlab
      ),
      dots
    )
  )
  graphics::abline(v = x$null_mean, lwd = 2, lty = 2, col = "#b40426")
  graphics::abline(v = x$observed_statistic, lwd = 2)
  graphics::legend(
    "topright",
    legend = c("Observed", "Null mean"),
    lty = c(1, 2),
    lwd = c(2, 2),
    col = c("black", "#b40426"),
    bty = "n"
  )
  invisible(x)
}

